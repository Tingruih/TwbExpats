{% extends 'base.j2' %}

{% block content %}

{# ── TAB SYSTEM (CSS radio-based, zero JS) ── #}
<input type="radio" name="profile-tab" id="tab-bio" class="tab-radio" checked>
<input type="radio" name="profile-tab" id="tab-stats" class="tab-radio">
<input type="radio" name="profile-tab" id="tab-gamelogs" class="tab-radio">
<input type="radio" name="profile-tab" id="tab-advanced" class="tab-radio">
<input type="radio" name="profile-tab" id="tab-fielding" class="tab-radio">

{# ── PLAYER HERO ── #}
<div class="profile-hero glass-panel" id="player-hero-{{ player.mlb_id }}">
    <div class="hero-photo-wrap">
        <div class="hero-avatar" id="avatar-{{ player.mlb_id }}">
            <img
                src="{{ base_url }}img/players/{{ player.mlb_id }}.jpg"
                data-cdn-src="https://img.mlbstatic.com/mlb-photos/image/upload/w_180,q_auto:best/v1/people/{{ player.mlb_id }}/headshot/milb/current"
                alt="{{ player.name_en }}"
                id="headshot-{{ player.mlb_id }}"
                class="avatar-img"
            >
            <div class="avatar-initials avatar-fallback" id="initials-{{ player.mlb_id }}" aria-hidden="true">
                {{ player.name_en[:1] }}
            </div>
        </div>
    </div>

    <div class="hero-info">
        <h1>{{ player.name_tw or player.name_en }}
            <span class="hero-name-en">{{ player.name_en }}</span>
        </h1>
        <div class="hero-meta">
            {% if player.source == 'mlb' and player.level != 'MLB' %}<span class="badge badge-mlb">MLB</span>{% endif %}
            <span class="badge badge-level">{{ player.level }}</span>
            <span class="hero-team">{{ player.team }}</span>
            <span class="hero-pos">{% if is_pitcher %}{{ (player.pitch_hand or "R") }}HP{% else %}{{ (player.bat_side or "?")[:1] }}{% endif %} · {{ player.position }}</span>
        </div>
    </div>

    {# ── KEY STATS STRIP ── #}
    {% if latest_team_stat %}
    {% set stat = latest_team_stat %}
    <div class="hero-stats-strip">
        {% if is_pitcher %}
            <div class="hs-item"><span class="hs-val">{{ stat.era|floatformat(2) }}</span><span class="hs-lbl">ERA</span></div>
            <div class="hs-item"><span class="hs-val">{{ stat.whip|floatformat(2) }}</span><span class="hs-lbl">WHIP</span></div>
            <div class="hs-item"><span class="hs-val">{{ stat.so|num_dash }}</span><span class="hs-lbl">K</span></div>
            <div class="hs-item"><span class="hs-val">{{ stat.wins|num_dash }}-{{ stat.losses|num_dash }}</span><span class="hs-lbl">W-L</span></div>
            <div class="hs-item"><span class="hs-val">{{ stat.ip|floatformat(1) }}</span><span class="hs-lbl">IP</span></div>
        {% else %}
            <div class="hs-item"><span class="hs-val">{{ stat.avg|floatformat(3) }}</span><span class="hs-lbl">AVG</span></div>
            <div class="hs-item"><span class="hs-val">{{ stat.ops|floatformat(3) }}</span><span class="hs-lbl">OPS</span></div>
            <div class="hs-item"><span class="hs-val">{{ stat.hr|num_dash }}</span><span class="hs-lbl">HR</span></div>
            <div class="hs-item"><span class="hs-val">{{ stat.rbi|num_dash }}</span><span class="hs-lbl">RBI</span></div>
            <div class="hs-item"><span class="hs-val">{{ stat.sb|num_dash }}</span><span class="hs-lbl">SB</span></div>
        {% endif %}
    </div>
    {% endif %}
</div>

{# ── TAB NAV ── #}
<div class="tab-nav glass-panel desktop-only">
    <label for="tab-bio" class="tab-label">球員資料</label>
    <label for="tab-stats" class="tab-label">歷年數據</label>
    <label for="tab-gamelogs" class="tab-label">逐場紀錄</label>
    <label for="tab-advanced" class="tab-label">進階數據</label>
    <label for="tab-fielding" class="tab-label">守備數據</label>
</div>

{# ── MOBILE TAB NAV ── #}
<div class="tab-nav-mobile glass-panel mobile-only">
    <div class="tab-nav-mobile-scroll">
        <label for="tab-bio" class="tab-mobile-label">球員資料</label>
        <label for="tab-stats" class="tab-mobile-label">歷年數據</label>
        <label for="tab-gamelogs" class="tab-mobile-label">逐場紀錄</label>
        <label for="tab-advanced" class="tab-mobile-label">進階數據</label>
        <label for="tab-fielding" class="tab-mobile-label">守備數據</label>
    </div>
</div>

{# ── TAB 1: BIO ── #}
<div class="tab-panel" id="panel-bio">

    <div class="bio-grid">
        {# Personal Info #}
        <div class="bio-card glass-panel">
            <h3 class="bio-card-title">個人資料</h3>
            <dl class="bio-dl">
                {% if player.birth_date %}
                <dt>出生日期</dt><dd>{{ player.birth_date }}{% if player.age %} ({{ player.age }}歲){% endif %}</dd>
                {% endif %}
                {% if player.birth_city or player.birth_country %}
                <dt>出生地</dt><dd>{{ player.birth_city }}{% if player.birth_city and player.birth_country %}, {% endif %}{{ player.birth_country }}</dd>
                {% endif %}
                {% if player.height %}
                <dt>身高</dt><dd>{{ player.height }}{% if height_cm %} ({{ height_cm }} cm){% endif %}</dd>
                {% endif %}
                {% if player.weight %}
                <dt>體重</dt><dd>{{ player.weight }} lbs{% if weight_kg %} ({{ weight_kg }} kg){% endif %}</dd>
                {% endif %}
                {% if player.bat_side %}
                <dt>打擊方向</dt><dd>{{ player.bat_side }}</dd>
                {% endif %}
                {% if player.pitch_hand %}
                <dt>投球手</dt><dd>{{ player.pitch_hand }}</dd>
                {% endif %}
                <dt>狀態</dt>
                <dd>
                    {% if player.roster_status %}
                        {% set s = player.roster_status %}
                        {% if "Injured" in s or "IL" in s or "DL" in s %}
                            <span class="status-pill injured">{{ s }}</span>
                        {% elif "Restricted" in s or "Suspended" in s or "Bereavement" in s %}
                            <span class="status-pill restricted">{{ s }}</span>
                        {% elif "Active" in s %}
                            <span class="status-pill active">{{ s }}</span>
                        {% else %}
                            <span class="status-pill other">{{ s }}</span>
                        {% endif %}
                    {% elif player.is_active %}
                        <span class="status-pill active">Active</span>
                    {% else %}
                        <span class="status-pill inactive">Inactive</span>
                    {% endif %}
                </dd>
            </dl>
        </div>

        {# Next Game #}
        {% if next_game %}
        <div class="bio-card glass-panel next-game-card">
            <h3 class="bio-card-title">Next Game</h3>
            <div class="next-game-info">
                <div class="ng-matchup">
                    <span class="ng-ha">{% if next_game.is_home %}vs{% else %}@{% endif %}</span>
                    <span class="ng-opponent">{{ next_game.opponent }}</span>
                </div>
                <div class="ng-details">
                    <span class="ng-time">{{ next_game.game_time }}</span>
                    {% if next_game.venue %}
                    <span class="ng-venue">{{ next_game.venue }}</span>
                    {% endif %}
                </div>

            </div>
        </div>
        {% else %}
        <div class="bio-card glass-panel next-game-card">
            <h3 class="bio-card-title">Next Game</h3>
            <p class="next-game-empty">近期尚無可用賽程資料</p>
        </div>
        {% endif %}

        {# Transaction History #}
        {% if transactions %}
        <div class="bio-card glass-panel tx-card">
            <h3 class="bio-card-title">異動紀錄 <span class="tx-count">({{ transactions|length }})</span></h3>
            <div class="tx-timeline">
                {% for tx in transactions %}
                <div class="tx-item">
                    <div class="tx-dot"></div>
                    <div class="tx-content">
                        <div class="tx-header">
                            <span class="tx-date">{{ tx.date }}</span>
                            {% if tx.type %}<span class="tx-type-badge">{{ tx.type }}</span>{% endif %}
                        </div>
                        <p class="tx-desc">{{ tx.description }}</p>
                    </div>
                </div>
                {% endfor %}
            </div>
        </div>
        {% elif player.latest_transaction %}
        <div class="bio-card glass-panel">
            <h3 class="bio-card-title">最新異動</h3>
            <p class="tx-desc">{{ player.latest_transaction }}</p>
        </div>
        {% endif %}

        {# ── COMBINED CAREER + SEASON CARD ── #}
        {% if total_career or player.latest_stat %}
        <div class="bio-card glass-panel career-combined-card">

            {# Total Career #}
            {% if total_career %}
            <h3 class="bio-card-title">生涯累計 ({{ total_career.years_range }})</h3>
            {% if is_pitcher %}
            <div class="mini-stats-grid highlight-only">
                <div class="ms-item"><span class="ms-v">{{ total_career.gp|num_dash }}</span><span class="ms-l">G</span></div>
                <div class="ms-item"><span class="ms-v">{{ total_career.era|floatformat(2) }}</span><span class="ms-l">ERA</span></div>
                <div class="ms-item"><span class="ms-v">{{ total_career.whip|floatformat(2) }}</span><span class="ms-l">WHIP</span></div>
                <div class="ms-item"><span class="ms-v">{{ total_career.so|num_dash }}</span><span class="ms-l">K</span></div>
                <div class="ms-item"><span class="ms-v">{{ total_career.wins|num_dash }}-{{ total_career.losses|num_dash }}</span><span class="ms-l">W-L</span></div>
                <div class="ms-item"><span class="ms-v">{{ total_career.ip|floatformat(1) if total_career.ip else '-' }}</span><span class="ms-l">IP</span></div>
            </div>
            {% else %}
            <div class="mini-stats-grid highlight-only">
                <div class="ms-item"><span class="ms-v">{{ total_career.gp|num_dash }}</span><span class="ms-l">G</span></div>
                <div class="ms-item"><span class="ms-v">{{ total_career.avg|floatformat(3) }}</span><span class="ms-l">AVG</span></div>
                <div class="ms-item"><span class="ms-v">{{ total_career.ops|floatformat(3) }}</span><span class="ms-l">OPS</span></div>
                <div class="ms-item"><span class="ms-v">{{ total_career.hr|num_dash }}</span><span class="ms-l">HR</span></div>
                <div class="ms-item"><span class="ms-v">{{ total_career.rbi|num_dash }}</span><span class="ms-l">RBI</span></div>
                <div class="ms-item"><span class="ms-v">{{ total_career.sb|num_dash }}</span><span class="ms-l">SB</span></div>
            </div>
            {% endif %}
            {% endif %}

            {# Divider #}
            {% if total_career and season_combined %}
            <div class="career-divider"></div>
            {% endif %}

            {# Current Season Combined #}
            {% if season_combined %}
            {% set sc = season_combined %}
            <h3 class="bio-card-title">{{ sc.year }} 賽季 — {{ sc.teams_display }}</h3>
            {% if is_pitcher %}
            <div class="mini-stats-grid highlight-only">
                <div class="ms-item"><span class="ms-v">{{ sc.gp|num_dash }}</span><span class="ms-l">G</span></div>
                <div class="ms-item"><span class="ms-v">{{ sc.era|floatformat(2) }}</span><span class="ms-l">ERA</span></div>
                <div class="ms-item"><span class="ms-v">{{ sc.whip|floatformat(2) }}</span><span class="ms-l">WHIP</span></div>
                <div class="ms-item"><span class="ms-v">{{ sc.so|num_dash }}</span><span class="ms-l">K</span></div>
                <div class="ms-item"><span class="ms-v">{{ sc.wins|num_dash }}-{{ sc.losses|num_dash }}</span><span class="ms-l">W-L</span></div>
                <div class="ms-item"><span class="ms-v">{{ sc.ip|floatformat(1) if sc.ip else '-' }}</span><span class="ms-l">IP</span></div>
            </div>
            {% else %}
            <div class="mini-stats-grid highlight-only">
                <div class="ms-item"><span class="ms-v">{{ sc.gp|num_dash }}</span><span class="ms-l">G</span></div>
                <div class="ms-item"><span class="ms-v">{{ sc.avg|floatformat(3) }}</span><span class="ms-l">AVG</span></div>
                <div class="ms-item"><span class="ms-v">{{ sc.ops|floatformat(3) }}</span><span class="ms-l">OPS</span></div>
                <div class="ms-item"><span class="ms-v">{{ sc.hr|num_dash }}</span><span class="ms-l">HR</span></div>
                <div class="ms-item"><span class="ms-v">{{ sc.rbi|num_dash }}</span><span class="ms-l">RBI</span></div>
                <div class="ms-item"><span class="ms-v">{{ sc.sb|num_dash }}</span><span class="ms-l">SB</span></div>
            </div>
            {% endif %}
            {% endif %}
        </div>
        {% endif %}
    </div>
</div>

{# ── TAB 2: SEASON STATS ── #}
<div class="tab-panel" id="panel-stats">

    {% if chart_data %}
    <div class="chart-wrap glass-panel">
        <h3>{{ selected_year }} 賽季走勢 — {% if is_pitcher %}ERA{% else %}AVG{% endif %}</h3>
        <canvas id="performanceChart" height="80"></canvas>
    </div>
    {% endif %}

    <div class="data-table-section glass-panel">
        <h3>歷年賽季成績</h3>
        <div class="table-scroll">
            <table class="data-table year-group-table" id="stats-table-basic">
                <thead>
                    <tr>
                        <th class="col-toggle"></th>
                        <th>年度</th><th>層級</th><th>球隊</th><th>聯盟</th><th>G</th>
                        {% if is_pitcher %}
                            <th>W</th><th>L</th><th>ERA</th><th>GS</th><th>CG</th><th>SHO</th>
                            <th>SV</th><th>HLD</th><th>IP</th><th>H</th><th>R</th><th>ER</th>
                            <th>HR</th><th>BB</th><th>SO</th><th>HB</th><th>WP</th><th>BK</th><th>TBF</th>
                        {% else %}
                            <th>PA</th><th>AB</th><th>R</th><th>H</th><th>2B</th><th>3B</th>
                            <th>HR</th><th>RBI</th><th>SB</th><th>CS</th><th>BB</th><th>SO</th>
                            <th>AVG</th><th>OBP</th><th>SLG</th><th>OPS</th><th>TB</th>
                            <th>XBH</th><th>GIDP</th><th>GIDPO</th><th>P/PA</th><th>ROE</th><th>WO</th>
                        {% endif %}
                    </tr>
                </thead>
                <tbody>
                    {% for grp in stats_year_groups %}
                    {% set yr = grp.year %}
                    {% set sm = grp.summary %}
                    {# ── Summary row ── #}
                    <tr class="year-summary-row {% if yr == selected_year %}highlight-row{% endif %}"
                        data-year="{{ yr }}"
                        {% if grp.multi %}onclick="toggleYearGroup('basic','{{ yr }}')" style="cursor:pointer;"{% endif %}>
                        <td class="col-toggle">
                            {% if grp.multi %}<span class="toggle-arrow" id="arrow-basic-{{ yr }}">▶</span>{% endif %}
                        </td>
                        <td><strong>{{ yr }}</strong></td>
                        <td>{% if grp.multi %}<span class="multi-tag">合計</span>{% else %}<span class="level-tag level-{{ grp.rows[0].sport_level|lower }}">{{ grp.rows[0].sport_level }}</span>{% endif %}</td>
                        <td>{% if not grp.multi %}{{ grp.rows[0].team_name }}{% else %}—{% endif %}</td>
                        <td class="td-league">{% if not grp.multi %}{{ grp.rows[0].league_name }}{% else %}—{% endif %}</td>
                        <td>{{ sm.gp|num_dash }}</td>
                        {% if is_pitcher %}
                            <td class="num">{{ sm.wins|num_dash }}</td>
                            <td class="num">{{ sm.losses|num_dash }}</td>
                            <td class="num">{{ sm.era|floatformat(2) }}</td>
                            <td class="num">{{ sm.gs|num_dash }}</td>
                            <td class="num">{{ sm.cg|num_dash }}</td>
                            <td class="num">{{ sm.sho|num_dash }}</td>
                            <td class="num">{{ sm.sv|num_dash }}</td>
                            <td class="num">{{ sm.hld|num_dash }}</td>
                            <td class="num">{{ sm.ip|floatformat(1) }}</td>
                            <td class="num">{{ sm.p_hits|num_dash }}</td>
                            <td class="num">{{ sm.runs_allowed|num_dash }}</td>
                            <td class="num">{{ sm.earned_runs|num_dash }}</td>
                            <td class="num">{{ sm.p_hr|num_dash }}</td>
                            <td class="num">{{ sm.bb|num_dash }}</td>
                            <td class="num">{{ sm.so|num_dash }}</td>
                            <td class="num">{{ sm.p_hbp|num_dash }}</td>
                            <td class="num">{{ sm.wp|num_dash }}</td>
                            <td class="num">{{ sm.balks|num_dash }}</td>
                            <td class="num">{{ sm.bf|num_dash }}</td>
                        {% else %}
                            <td class="num">{{ sm.pa|num_dash }}</td>
                            <td class="num">{{ sm.ab|num_dash }}</td>
                            <td class="num">{{ sm.runs|num_dash }}</td>
                            <td class="num">{{ sm.hits|num_dash }}</td>
                            <td class="num">{{ sm.doubles|num_dash }}</td>
                            <td class="num">{{ sm.triples|num_dash }}</td>
                            <td class="num">{{ sm.hr|num_dash }}</td>
                            <td class="num">{{ sm.rbi|num_dash }}</td>
                            <td class="num">{{ sm.sb|num_dash }}</td>
                            <td class="num">{{ sm.cs|num_dash }}</td>
                            <td class="num">{{ sm.hit_bb|num_dash }}</td>
                            <td class="num">{{ sm.h_so|num_dash }}</td>
                            <td class="num">{{ sm.avg|floatformat(3) }}</td>
                            <td class="num">{{ sm.obp|floatformat(3) }}</td>
                            <td class="num">{{ sm.slg|floatformat(3) }}</td>
                            <td class="num">{{ sm.ops|floatformat(3) }}</td>
                            <td class="num">{{ sm.tb|num_dash }}</td>
                            <td class="num">{{ sm.xbh|num_dash }}</td>
                            <td class="num">{{ sm.gdp|num_dash }}</td>
                            <td class="num">{{ sm.gidpo|num_dash }}</td>
                            <td class="num">{{ sm.p_per_pa|floatformat(2) }}</td>
                            <td class="num">{{ sm.roe|num_dash }}</td>
                            <td class="num">{{ sm.wo|num_dash }}</td>
                        {% endif %}
                    </tr>
                    {# ── Per-team detail rows (hidden by default when multi) ── #}
                    {% if grp.multi %}
                    {% for stat in grp.rows %}
                    <tr class="year-detail-row" data-tbl="basic" data-grp="{{ yr }}" style="display:none;">
                        <td></td>
                        <td></td>
                        <td><span class="level-tag level-{{ stat.sport_level|lower }}">{{ stat.sport_level }}</span></td>
                        <td>{{ stat.team_name }}</td>
                        <td class="td-league">{{ stat.league_name }}</td>
                        <td>{{ stat.gp|num_dash }}</td>
                        {% if is_pitcher %}
                            <td class="num">{{ stat.wins|num_dash }}</td>
                            <td class="num">{{ stat.losses|num_dash }}</td>
                            <td class="num">{{ stat.era|floatformat(2) }}</td>
                            <td class="num">{{ stat.gs|num_dash }}</td>
                            <td class="num">{{ stat.cg|num_dash }}</td>
                            <td class="num">{{ stat.sho|num_dash }}</td>
                            <td class="num">{{ stat.sv|num_dash }}</td>
                            <td class="num">{{ stat.hld|num_dash }}</td>
                            <td class="num">{{ stat.ip|floatformat(1) }}</td>
                            <td class="num">{{ stat.p_hits|num_dash }}</td>
                            <td class="num">{{ stat.runs_allowed|num_dash }}</td>
                            <td class="num">{{ stat.earned_runs|num_dash }}</td>
                            <td class="num">{{ stat.p_hr|num_dash }}</td>
                            <td class="num">{{ stat.bb|num_dash }}</td>
                            <td class="num">{{ stat.so|num_dash }}</td>
                            <td class="num">{{ stat.p_hbp|num_dash }}</td>
                            <td class="num">{{ stat.wp|num_dash }}</td>
                            <td class="num">{{ stat.balks|num_dash }}</td>
                            <td class="num">{{ stat.bf|num_dash }}</td>
                        {% else %}
                            <td class="num">{{ stat.pa|num_dash }}</td>
                            <td class="num">{{ stat.ab|num_dash }}</td>
                            <td class="num">{{ stat.runs|num_dash }}</td>
                            <td class="num">{{ stat.hits|num_dash }}</td>
                            <td class="num">{{ stat.doubles|num_dash }}</td>
                            <td class="num">{{ stat.triples|num_dash }}</td>
                            <td class="num">{{ stat.hr|num_dash }}</td>
                            <td class="num">{{ stat.rbi|num_dash }}</td>
                            <td class="num">{{ stat.sb|num_dash }}</td>
                            <td class="num">{{ stat.cs|num_dash }}</td>
                            <td class="num">{{ stat.hit_bb|num_dash }}</td>
                            <td class="num">{{ stat.h_so|num_dash }}</td>
                            <td class="num">{{ stat.avg|floatformat(3) }}</td>
                            <td class="num">{{ stat.obp|floatformat(3) }}</td>
                            <td class="num">{{ stat.slg|floatformat(3) }}</td>
                            <td class="num">{{ stat.ops|floatformat(3) }}</td>
                            <td class="num">{{ stat.tb|num_dash }}</td>
                            <td class="num">{{ stat.xbh|num_dash }}</td>
                            <td class="num">{{ stat.gdp|num_dash }}</td>
                            <td class="num">{{ stat.gidpo|num_dash }}</td>
                            <td class="num">{{ stat.p_per_pa|floatformat(2) }}</td>
                            <td class="num">{{ stat.roe|num_dash }}</td>
                            <td class="num">{{ stat.wo|num_dash }}</td>
                        {% endif %}
                    </tr>
                    {% endfor %}
                    {% endif %}
                    {% else %}
                    <tr><td colspan="32" class="td-empty">尚無數據</td></tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
</div>

{# ── TAB 3: GAME LOGS ── #}
<div class="tab-panel" id="panel-gamelogs">

    {# Year indicator #}
    <div class="year-selector glass-panel">
        <span class="year-label">年度：</span>
        {% for y in available_log_years %}
            <span class="year-btn gamelog-year-btn {% if loop.first %}year-btn-active{% endif %}" data-year="{{ y }}" style="cursor: pointer;">{{ y }}</span>
        {% else %}
            <span class="year-btn year-btn-active">{{ selected_year }}</span>
        {% endfor %}
    </div>

    {% for y in available_log_years %}
    {% set year_logs = logs_by_year[y] %}
    <div class="gamelog-table-container data-table-section glass-panel" id="gamelogs-{{ y }}" {% if not loop.first %}style="display: none;"{% endif %}>
        <h3>{{ y }} 逐場比賽紀錄</h3>
        <div class="table-scroll">
            <table class="data-table">
                <thead>
                    <tr>
                        <th>日期</th><th>H/A</th><th>對手</th>
