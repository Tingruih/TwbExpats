                        <td class="num">{{ f.chances|num_dash }}</td>
                        <td class="num">{{ f.putouts|num_dash }}</td>
                        <td class="num">{{ f.assists|num_dash }}</td>
                        <td class="num">{{ f.errors|num_dash }}</td>
                        <td class="num">{{ f.fielding_pct|num_dash }}</td>
                        <td class="num">{{ f.dp|num_dash }}</td>
                        <td class="num">{{ f.tp|num_dash }}</td>
                        <td class="num">{{ f.range_factor_game|num_dash }}</td>
                        <td class="num">{{ f.range_factor_9|num_dash }}</td>
                        <td class="num">{{ f.throwing_errors|num_dash }}</td>
                    </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
    {% else %}
    <div class="glass-panel empty-season-msg">
        尚無守備數據
    </div>
    {% endif %}
</div>
{% endblock %}

{% block extra_scripts %}
{# Year-group expand/collapse for stats tables #}
<script>
function toggleYearGroup(tableId, yr) {
    // Find all detail rows for this table + year
    const table = document.getElementById('stats-table-' + tableId);
    if (!table) return;
    const rows = table.querySelectorAll('tr[data-tbl="' + tableId + '"][data-grp="' + yr + '"]');
    const arrow = document.getElementById('arrow-' + tableId + '-' + yr);
    const open = rows.length > 0 && rows[0].style.display !== 'none';
    rows.forEach(r => r.style.display = open ? 'none' : '');
    if (arrow) arrow.style.transform = open ? '' : 'rotate(90deg)';
}
</script>

{# Game log year toggle #}
<script>
document.addEventListener("DOMContentLoaded", function() {
    const btns = document.querySelectorAll(".gamelog-year-btn");
    const tables = document.querySelectorAll(".gamelog-table-container");
    btns.forEach(btn => {
        btn.addEventListener("click", function() {
            btns.forEach(b => b.classList.remove("year-btn-active"));
            tables.forEach(t => t.style.display = "none");
            
            this.classList.add("year-btn-active");
            const y = this.dataset.year;
            const tbl = document.getElementById("gamelogs-" + y);
            if (tbl) tbl.style.display = "block";
        });
    });
});
</script>

{# Chart.js — CDN only loaded when chart data exists to avoid unused requests #}
{% if chart_data %}
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script type="application/json" id="chart-labels">{{ chart_labels|tojson_safe }}</script>
<script type="application/json" id="chart-data">{{ chart_data|tojson_safe }}</script>
<script>
document.addEventListener("DOMContentLoaded", function () {
    const canvas = document.getElementById("performanceChart");
    if (!canvas) return;
    const ctx = canvas.getContext("2d");
    const labels = JSON.parse(document.getElementById("chart-labels").textContent);
    const data   = JSON.parse(document.getElementById("chart-data").textContent);

    let grad = ctx.createLinearGradient(0, 0, 0, 300);
    grad.addColorStop(0, "rgba(20,184,166,0.35)");
    grad.addColorStop(1, "rgba(20,184,166,0.0)");

    new Chart(ctx, {
        type: "line",
        data: {
            labels,
            datasets: [{
                label: "{% if is_pitcher %}ERA{% else %}AVG{% endif %}",
                data,
                borderColor: "#14b8a6",
                backgroundColor: grad,
                borderWidth: 2.5,
                pointBackgroundColor: "#14b8a6",
                pointBorderColor: "#09090b",
                pointBorderWidth: 2,
                pointRadius: 4,
                pointHoverRadius: 6,
                fill: true,
                tension: 0.35,
            }]
        },
        options: {
            responsive: true,
            plugins: { legend: { labels: { color: "#f8fafc" } } },
            scales: {
                x: { grid: { color: "rgba(255,255,255,0.05)" }, ticks: { color: "#94a3b8" } },
                y: {
                    grid: { color: "rgba(255,255,255,0.05)" }, ticks: { color: "#94a3b8" },
                    reverse: {% if is_pitcher %}true{% else %}false{% endif %}
                }
            }
        }
    });
});
</script>
{% endif %}

{# Image fallback handler (fixes E2 - no inline onerror) #}
<script>
document.addEventListener("DOMContentLoaded", function () {
    document.querySelectorAll(".avatar-img").forEach(function(img) {
        img.addEventListener("error", function() {
            if (!this.dataset.cdnTried) {
                // First failure: try the MLB CDN URL
                this.dataset.cdnTried = "1";
                var cdn = this.dataset.cdnSrc;
                if (cdn) { this.src = cdn; return; }
            }
            // CDN also failed: show initials fallback
            this.style.display = "none";
            var fallback = this.parentElement.querySelector(".avatar-fallback");
            if (fallback) fallback.style.display = "flex";
        });
    });
});
</script>

{# Tab restoration from query param #}
<script>
(function(){
    var p = new URLSearchParams(location.search).get("tab");
    if (p === "stats")    document.getElementById("tab-stats").checked = true;
    if (p === "gamelogs") document.getElementById("tab-gamelogs").checked = true;
    if (p === "advanced") document.getElementById("tab-advanced").checked = true;
    if (p === "fielding") document.getElementById("tab-fielding").checked = true;
})();
</script>

{# Wheel → horizontal scroll for all data tables #}
<script>
document.querySelectorAll(".table-scroll").forEach(function(el) {
    el.addEventListener("wheel", function(e) {
        if (e.deltaY === 0) return;
        e.preventDefault();
        el.scrollLeft += e.deltaY;
    }, { passive: false });
});
</script>
{% endblock %}

