{% extends 'base.j2' %}
{% import "macros/tags.j2" as tags %}

{% block content %}

{# ─── Controls bar: sort buttons + build time ─── #}
<div class="index-controls">
    <div class="sort-bar glass-panel" id="sort-bar">
        <span class="sort-label">排序：</span>
        <button class="sort-btn sort-btn-active" id="btn-level" onclick="sortCards('level')">層級</button>
        <button class="sort-btn" id="btn-recent" onclick="sortCards('recent')">最近出賽</button>
    </div>
</div>

<div class="dashboard-grid" id="player-grid">
    {% for item in player_data %}
    {% set player = item.player %}
    {% set stat = item.stat %}
    {% set player_name = player.name_tw ~ ' ' ~ player.name_en if player.name_tw else player.name_en %}
    <a href="{{ player_url(player.mlb_id) }}" class="player-card glass-panel"
       data-level="{{ player.level | level_display(item.level_year) }}"
       data-level-order="{{ loop.index }}"
       data-last-game="{{ item.last_game_date.isoformat() if item.last_game_date else '0000-00-00' }}">
        <div class="player-header">
            <div class="avatar">
                {# 頭像：data-src 交給 avatar-fallback.js 分批 lazy 載入 #}
                {% set cdn_primary, cdn_secondary = headshot_cdn_urls(player.mlb_id, player.latest_level_is_mlb) %}
                <img data-src="{{ cdn_primary }}" data-cdn-src="{{ cdn_secondary }}" alt="{{ player_name }}" class="avatar-img">
                <div class="avatar-initials avatar-fallback" aria-hidden="true">{{ player.name_en[:1] }}</div>
            </div>
            <div class="player-info">
                <h2>{{ player.name_tw or player.name_en }}
                    {{ tags.level_tag(player.level, item.level_year) }}
                </h2>
                <div class="level">{{ player.position }}</div>
            </div>
        </div>

        {% if stat %}
        <div class="stats-row">
            {% if player.is_pitcher %}
                <div class="stat-box">
                    <span class="stat-label">ERA</span>
                    <span class="stat-value">{{ stat.era|floatformat(2) }}</span>
                </div>
                <div class="stat-box">
                    <span class="stat-label">WHIP</span>
                    <span class="stat-value">{{ stat.whip|floatformat(2) }}</span>
                </div>
                <div class="stat-box">
                    <span class="stat-label">K</span>
                    <span class="stat-value">{{ stat.so|num_dash }}</span>
                </div>
                <div class="stat-box">
                    <span class="stat-label">W-L</span>
                    <span class="stat-value">{{ stat.wins|num_dash }}-{{ stat.losses|num_dash }}</span>
                </div>
            {% else %}
                <div class="stat-box">
                    <span class="stat-label">AVG</span>
                    <span class="stat-value">{{ stat.avg|floatformat(3) }}</span>
                </div>
                <div class="stat-box">
                    <span class="stat-label">HR</span>
                    <span class="stat-value">{{ stat.hr|num_dash }}</span>
                </div>
                <div class="stat-box">
                    <span class="stat-label">OPS</span>
                    <span class="stat-value">{{ stat.ops|floatformat(3) }}</span>
                </div>
                <div class="stat-box">
                    <span class="stat-label">SB</span>
                    <span class="stat-value">{{ stat.sb|num_dash }}</span>
                </div>
            {% endif %}
        </div>
        {% else %}
        <div class="stats-row stats-row-empty">
            <div class="stat-box stat-box-full">
                <span class="stat-label">{{ default_season_year }} 尚無出賽紀錄</span>
            </div>
        </div>
        {% endif %}
    </a>
    {% else %}
    <p class="empty-msg">尚無球員資料，資料尚未同步。</p>
    {% endfor %}
</div>
{% endblock %}

{% block extra_scripts %}
<script defer src="{{ static_url('js/index-sort.js') }}"></script>
{% endblock %}
