{# ── 手機版 TAB：守備數據（統一 mc-* 數據卡片系統）── #}
{% macro mcell(label, value) -%}
<div class="mc-cell"><b>{{ label }}</b><span>{{ value }}</span></div>
{%- endmacro %}

<section class="m-section-stack" aria-label="守備數據">
    {% if all_fielding %}
    <div class="glass-panel m-data-sec">
        <h3>歷年守備數據</h3>
        <div class="mc-list">
            {% for f in all_fielding %}
            <article class="mc-card">
                <header class="mc-hd">
                    <div class="mc-hd-meta">
                        <span class="mc-yr">{{ f.year }}</span>
                        <span class="level-tag level-{{ f.sport_level|lower }}">{{ f.sport_level }}</span>
                        <span class="mc-team">{{ f.team_name }}</span>
                    </div>
                    <div class="mc-hd-aside">
                        <span class="pos-tag">{{ f.position }}</span>
                    </div>
                </header>
                <div class="mc-hero">
                    <div class="mc-hero-cell"><span>{{ f.fielding_pct|num_dash }}</span><b>FLD%</b></div>
                    <div class="mc-hero-cell"><span>{{ f.innings|num_dash }}</span><b>INN</b></div>
                    <div class="mc-hero-cell"><span>{{ f.errors|num_dash }}</span><b>E</b></div>
                    <div class="mc-hero-cell"><span>{{ f.dp|num_dash }}</span><b>DP</b></div>
                </div>
                <div class="mc-grid mc-grid--3">
                    {{ mcell('GP', f.gp|num_dash) }}
                    {{ mcell('GS', f.gs|num_dash) }}
                    {{ mcell('TC', f.chances|num_dash) }}
                    {{ mcell('PO', f.putouts|num_dash) }}
                    {{ mcell('A', f.assists|num_dash) }}
                    {{ mcell('TP', f.tp|num_dash) }}
                    {{ mcell('RF/G', f.range_factor_game|num_dash) }}
                    {{ mcell('RF/9', f.range_factor_9|num_dash) }}
                    {{ mcell('TE', f.throwing_errors|num_dash) }}
                </div>
            </article>
            {% endfor %}
        </div>
    </div>
    {% else %}
    <div class="glass-panel empty-season-msg">尚無守備數據</div>
    {% endif %}
</section>
