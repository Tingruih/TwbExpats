</div>

{# ── TAB 4: ADVANCED STATS ── #}
<div class="tab-panel" id="panel-advanced">

    {# Stat Definitions #}
    <div class="adv-definitions glass-panel">
        <h3>進階數據說明</h3>
        {% if is_pitcher %}
        <div class="def-grid">
            <div class="def-item"><span class="def-abbr">K/BB</span><span class="def-text">Strikeout-to-Walk Ratio — 三振保送比</span></div>
            <div class="def-item"><span class="def-abbr">K%</span><span class="def-text">Strikeout Rate — 三振率 = SO / BF</span></div>
            <div class="def-item"><span class="def-abbr">BB%</span><span class="def-text">Walk Rate — 保送率 = BB / BF</span></div>
            <div class="def-item"><span class="def-abbr">HR/9</span><span class="def-text">Home Runs per 9 IP — 每9局被全壘打數</span></div>
            <div class="def-item"><span class="def-abbr">P/IP</span><span class="def-text">Pitches per Inning — 每局用球數</span></div>
            <div class="def-item"><span class="def-abbr">S%</span><span class="def-text">Strike Percentage — 好球率</span></div>
            <div class="def-item"><span class="def-abbr">WPCT</span><span class="def-text">Win Percentage — 勝率</span></div>
            <div class="def-item"><span class="def-abbr">BABIP</span><span class="def-text">Batting Average on Balls In Play — 場內打擊率，聯盟平均約 .300</span></div>
            <div class="def-item"><span class="def-abbr">GO/AO</span><span class="def-text">Ground Outs / Air Outs — 滾飛比，>1 為滾地球型投手</span></div>
            <div class="def-item"><span class="def-abbr">AVG</span><span class="def-text">Batting Average Against — 被打擊率</span></div>
            <div class="def-item"><span class="def-abbr">OBP</span><span class="def-text">On-Base Percentage Against — 被上壘率</span></div>
            <div class="def-item"><span class="def-abbr">SLG</span><span class="def-text">Slugging Against — 被長打率</span></div>
            <div class="def-item"><span class="def-abbr">OPS</span><span class="def-text">OPS Against — 被攻擊指數</span></div>
            <div class="def-item"><span class="def-abbr">NP</span><span class="def-text">Number of Pitches — 投球總數</span></div>
            <div class="def-item"><span class="def-abbr">IBB</span><span class="def-text">Intentional Walks — 故意四壞球</span></div>
            <div class="def-item"><span class="def-abbr">QS</span><span class="def-text">Quality Starts — 優質先發（6局以上且自責分3以下）</span></div>
            <div class="def-item"><span class="def-abbr">GF</span><span class="def-text">Games Finished — 終結比賽數</span></div>
            <div class="def-item"><span class="def-abbr">SVO</span><span class="def-text">Save Opportunities — 救援機會</span></div>
            <div class="def-item"><span class="def-abbr">2B</span><span class="def-text">Doubles Allowed — 被二壘安打</span></div>
            <div class="def-item"><span class="def-abbr">3B</span><span class="def-text">Triples Allowed — 被三壘安打</span></div>
            <div class="def-item"><span class="def-abbr">GIDP</span><span class="def-text">Ground Into Double Play — 製造雙殺</span></div>
            <div class="def-item"><span class="def-abbr">CS</span><span class="def-text">Caught Stealing — 阻殺盜壘</span></div>
            <div class="def-item"><span class="def-abbr">SB</span><span class="def-text">Stolen bases (against) — 投球時被盜壘成功次數</span></div>
            <div class="def-item"><span class="def-abbr">P/PA</span><span class="def-text">Pitches per Plate Appearance — 每打席用球數</span></div>
            <div class="def-item"><span class="def-abbr">IR</span><span class="def-text">Inherited Runners — 繼承跑者</span></div>
            <div class="def-item"><span class="def-abbr">IR_S</span><span class="def-text">Inherited Runners Scored — 繼承跑者得分</span></div>
            <div class="def-item"><span class="def-abbr">WP</span><span class="def-text">Wild Pitches — 暴投</span></div>
            <div class="def-item"><span class="def-abbr">BK</span><span class="def-text">Balks — 投手犯規</span></div>
            <div class="def-item"><span class="def-abbr">PK</span><span class="def-text">Pickoffs — 牽制出局</span></div>
        </div>
        {% else %}
        <div class="def-grid">
            <div class="def-item"><span class="def-abbr">ISO</span><span class="def-text">Isolated Power — 純長打率 = SLG - AVG</span></div>
            <div class="def-item"><span class="def-abbr">BABIP</span><span class="def-text">Batting Average on Balls In Play — 場內打擊率，聯盟平均約 .300</span></div>
            <div class="def-item"><span class="def-abbr">K%</span><span class="def-text">Strikeout Rate — 三振率 = SO / PA</span></div>
            <div class="def-item"><span class="def-abbr">BB%</span><span class="def-text">Walk Rate — 保送率 = BB / PA</span></div>
            <div class="def-item"><span class="def-abbr">XBH</span><span class="def-text">Extra-Base Hits — 長打 = 2B + 3B + HR</span></div>
            <div class="def-item"><span class="def-abbr">AB/HR</span><span class="def-text">At Bats per Home Run — 每幾個打數擊出一支全壘打</span></div>
            <div class="def-item"><span class="def-abbr">GO/AO</span><span class="def-text">Ground Outs / Air Outs — 滾飛比</span></div>
            <div class="def-item"><span class="def-abbr">SB%</span><span class="def-text">Stolen Base Percentage — 盜壘成功率</span></div>
            <div class="def-item"><span class="def-abbr">LOB</span><span class="def-text">Left On Base — 殘壘數</span></div>
            <div class="def-item"><span class="def-abbr">P/PA</span><span class="def-text">Pitches per PA — 每打席面對球數</span></div>
            <div class="def-item"><span class="def-abbr">IBB</span><span class="def-text">Intentional Walks — 故意四壞球</span></div>
            <div class="def-item"><span class="def-abbr">GIDP</span><span class="def-text">Ground Into Double Play — 打成雙殺</span></div>
            <div class="def-item"><span class="def-abbr">GIDPO</span><span class="def-text">GIDP Opportunities — 雙殺機會</span></div>
            <div class="def-item"><span class="def-abbr">ROE</span><span class="def-text">Reached On Error — 因失誤上壘</span></div>
            <div class="def-item"><span class="def-abbr">WO</span><span class="def-text">Walk-Off — 再見安打</span></div>
            <div class="def-item"><span class="def-abbr">SF</span><span class="def-text">Sacrifice Flies — 高飛犧牲打</span></div>
            <div class="def-item"><span class="def-abbr">SH</span><span class="def-text">Sacrifice Hits — 犧牲觸擊</span></div>
        </div>
        {% endif %}
    </div>

