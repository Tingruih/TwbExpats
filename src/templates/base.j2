<!DOCTYPE html>
<html lang="zh-Hant">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}TwbExpats{% endblock %}</title>
    <meta name="description" content="一個追蹤台灣旅美棒球員的數據網站，提供即時比賽成績與所有進階數據。">
    <meta name="google-site-verification" content="E4BiMPJjMMJhQRbNItGI0T2WfvqxYQRZPO4z7kNUDQ4" />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="{{ static_url('css/style.css') }}">
    <link rel="icon" href="{{ static_url('logo.svg') }}" type="image/svg+xml">
    {% block extra_head %}{% endblock %}
</head>
<body>
    <div class="container">
        <header class="glass-panel">
            <a href="{{ base_url }}index.html" class="brand-logo">
                <img class="brand-icon" src="{{ static_url('logo.svg') }}" alt="TwbExpats logo">
                <div class="brand-copy">
                    <h1 class="brand-text">TwbExpats</h1>
                </div>
            </a>
            <div class="header-time-badge">
                <span>更新：{{ build_time }} (UTC+8)</span>
            </div>
        </header>

        <main>
            {% block content %}{% endblock %}
        </main>
    </div>
    {% block extra_scripts %}{% endblock %}

<script>
(function () {
    function rowsFor(table) {
        var rows = [];
        Array.prototype.forEach.call(table.tBodies, function (tbody) {
            Array.prototype.forEach.call(tbody.rows, function (row) {
                if (row.cells.length) rows.push(row);
            });
        });
        return rows;
    }

    function markNumericHeaders(table) {
        if (!table.tHead || !table.tHead.rows.length) return;

        var headerRow = table.tHead.rows[table.tHead.rows.length - 1];
        var bodyRows = rowsFor(table);
        Array.prototype.forEach.call(headerRow.cells, function (header, index) {
            var match = bodyRows.find(function (row) {
                return row.cells.length > index && row.cells[index].colSpan === 1;
            });
            header.classList.toggle("num", !!match && match.cells[index].classList.contains("num"));
        });
    }

    window.alignNumericTableColumns = function (root) {
        var scope = root || document;
        scope.querySelectorAll(".data-table, .pitch-log-table").forEach(markNumericHeaders);
    };

    document.addEventListener("DOMContentLoaded", function () {
        window.alignNumericTableColumns(document);
    });
}());
</script>

{# Shared image fallback handler — tries CDN URL first, then shows initials #}
<script>
document.addEventListener("DOMContentLoaded", function () {
    document.querySelectorAll(".avatar-img").forEach(function(img) {
        img.addEventListener("error", function() {
            if (!this.dataset.cdnTried) {
                this.dataset.cdnTried = "1";
                var cdn = this.dataset.cdnSrc;
                if (cdn) { this.src = cdn; return; }
            }
            this.style.display = "none";
            var fallback = this.parentElement.querySelector(".avatar-fallback");
            if (fallback) fallback.style.display = "flex";
        });
    });
});
</script>
<script defer src="https://static.cloudflareinsights.com/beacon.min.js" data-cf-beacon='{"token": "82c9ad15d468431086cbda577cc808a0"}'></script>
</body>
</html> 