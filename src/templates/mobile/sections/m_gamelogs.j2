{# ── 手機版 TAB：比賽紀錄（統一 mc-* 數據卡片系統）── #}
{% import "macros/tags.j2" as tags %}
{% macro mcell(label, value) -%}
<div class="mc-cell"><b>{{ label }}</b><span>{{ value }}</span></div>
{%- endmacro %}

<section class="m-section-stack" aria-label="逐場紀錄">
    <div class="m-filter-bar glass-panel">
        <label class="filter-label" for="m-gamelog-year-select">年度</label>
        <select id="m-gamelog-year-select" class="filter-select">
            {% for y in available_log_years %}
            <option value="{{ y }}"{% if loop.first %} selected{% endif %}>{{ y }}</option>
            {% else %}
            <option value="{{ selected_year }}" selected>{{ selected_year }}</option>
            {% endfor %}
        </select>
        <label class="filter-label" for="m-gamelog-level-select">層級</label>
        <select id="m-gamelog-level-select" class="filter-select"></select>
    </div>

    {% for y in available_log_years %}
    {% set year_logs = logs_by_year[y] %}
    <div class="m-gamelog-year" id="m-gamelogs-{{ y }}" {% if not loop.first %}style="display:none;"{% endif %}>
        {% for log in year_logs %}
        {% set s = log.stats_json %}
        <article class="m-gamelog-card mc-card" data-level="{{ log.sport_level | level_display(y) }}">

            {# ── 標題列：日期 / 主客 / 對手 ↔ 結果徽章 / 層級 ── #}
            <header class="mc-hd m-gamelog-hd">
                <div class="m-gamelog-hd-main">
                    <time>{{ log.date }}</time>
                    <div class="m-gamelog-opp">
                        {{ tags.ha_tag(log.is_home) }}
                        <strong>{{ log.opponent }}</strong>
                    </div>
                </div>
                <div class="mc-hd-aside">
                    {{ tags.level_tag(log.sport_level, y) }}
                </div>
            </header>

            {# ── 核心指標 + 完整明細（涵蓋電腦版所有欄位）── #}
            {% if is_pitcher %}
            <div class="mc-hero">
                <div class="mc-hero-cell"><span>{{ s.inningsPitched|num_dash }}</span><b>IP</b></div>
                <div class="mc-hero-cell"><span>{{ s.earnedRuns|default_if_none("0") }}</span><b>ER</b></div>
                <div class="mc-hero-cell"><span>{{ s.strikeOuts|default_if_none("0") }}</span><b>SO</b></div>
                <div class="mc-hero-cell"><span>{{ s.era|num_dash }}</span><b>ERA</b></div>
            </div>
            <div class="mc-grid mc-grid--3">
                {{ mcell('H', s.hits|default_if_none("0")) }}
                {{ mcell('R', s.runs|default_if_none("0")) }}
                {{ mcell('BB', s.baseOnBalls|default_if_none("0")) }}
                {{ mcell('HR', s.homeRuns|default_if_none("0")) }}
                {{ mcell('HB', s.hitByPitch|default_if_none("0")) }}
                <div class="mc-cell"><b>結果</b><span>
                    {% if s.wins %}<i class="mc-badge mc-badge--w">勝投</i>
                    {%- elif s.losses %}<i class="mc-badge mc-badge--l">敗投</i>
                    {%- elif s.saves %}<i class="mc-badge mc-badge--sv">救援</i>
                    {%- elif s.holds %}<i class="mc-badge mc-badge--hld">中繼</i>
                    {%- else %}—{% endif %}
                </span></div>
            </div>
            {% else %}
            <div class="mc-hero">
                <div class="mc-hero-cell"><span>{{ s.atBats|default_if_none("0") }}</span><b>AB</b></div>
                <div class="mc-hero-cell"><span>{{ s.hits|default_if_none("0") }}</span><b>H</b></div>
                <div class="mc-hero-cell"><span>{{ s.homeRuns|default_if_none("0") }}</span><b>HR</b></div>
                <div class="mc-hero-cell"><span>{{ s.rbi|default_if_none("0") }}</span><b>RBI</b></div>
            </div>
            <div class="mc-grid mc-grid--3">
                {{ mcell('R', s.runs|default_if_none("0")) }}
                {{ mcell('2B', s.doubles|default_if_none("0")) }}
                {{ mcell('3B', s.triples|default_if_none("0")) }}
                {{ mcell('BB', s.baseOnBalls|default_if_none("0")) }}
                {{ mcell('K', s.strikeOuts|default_if_none("0")) }}
                {{ mcell('SB', s.stolenBases|default_if_none("0")) }}
                {{ mcell('CS', s.caughtStealing|default_if_none("0")) }}
                {{ mcell('AVG', s.avg|num_dash) }}
                {{ mcell('OPS', s.ops|num_dash) }}
            </div>
            {% endif %}

            {# ── 逐球紀錄（保留原 JS 掛載結構）── #}
            {% if log.pitch_data_url %}
            <button type="button" class="m-pitch-log-toggle" onclick="toggleMobilePitchLog('m-pitchlog-{{ y }}-{{ loop.index }}')">
                <span class="toggle-arrow" id="m-arrow-pitchlog-{{ y }}-{{ loop.index }}"></span>
                <span>逐球紀錄</span>
            </button>
            <div class="m-pitch-log-panel" id="m-pitchlog-{{ y }}-{{ loop.index }}" data-src="{{ log.pitch_data_url }}" style="display:none;">
                <div class="pitch-log-scroll m-pitch-log-scroll" id="m-pitchlog-content-{{ y }}-{{ loop.index }}"></div>
            </div>
            {% endif %}
        </article>
        {% endfor %}
    </div>
    {% endfor %}

    {% if not available_log_years %}
    <div class="glass-panel empty-season-msg">{{ selected_year }} 尚無出賽紀錄</div>
    {% endif %}
</section>
