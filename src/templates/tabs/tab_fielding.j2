{# ── TAB 5: FIELDING STATS ── #}
{% import "macros/table.j2" as macros %}
{% import "macros/tags.j2" as tags %}
<div class="tab-panel" id="panel-fielding">

    {% if all_fielding %}
    <div class="data-table-section glass-panel">
        <h3>歷年守備數據</h3>
        <div class="table-scroll">
            <table class="data-table">
                <thead>
                    <tr>
                        <th>年度</th><th>層級</th><th>球隊</th>{{ macros.th('POS', '守備位置') }}
                        {{ macros.th('GP', '出賽數') }}{{ macros.th('GS', '先發場次') }}{{ macros.th('INN', '守備局數') }}
                        {{ macros.th('TC', '守備機會：PO+A+E') }}{{ macros.th('PO', '刺殺數') }}{{ macros.th('A', '助殺數') }}{{ macros.th('E', '失誤數') }}
                        {{ macros.th('FLD%', '守備率：(PO+A) ÷ TC') }}{{ macros.th('DP', '雙殺數') }}{{ macros.th('TP', '三殺數') }}
                        {{ macros.th('RF/G', '每場守備範圍因子') }}{{ macros.th('RF/9', '每9局守備範圍因子') }}{{ macros.th('TE', '傳球失誤數') }}
                    </tr>
                </thead>
                <tbody>
                    {% for f in all_fielding %}
                    <tr class="{% if f.year == selected_year %}highlight-row{% endif %}">
                        <td>{{ f.year }}</td>
                        <td>{{ tags.level_tag(f.sport_level, f.year) }}</td>
                        <td>{{ f.team_name }}</td>
                        <td><span class="pos-tag">{{ f.position }}</span></td>
                        <td class="num">{{ f.gp|num_dash }}</td>
                        <td class="num">{{ f.gs|num_dash }}</td>
                        <td class="num">{{ f.innings|num_dash }}</td>
                        <td class="num">{{ f.chances|num_dash }}</td>
                        <td class="num">{{ f.putouts|num_dash }}</td>
                        <td class="num">{{ f.assists|num_dash }}</td>
                        <td class="num">{{ f.errors|num_dash }}</td>
                        <td class="num">{{ f.fielding_pct|num_dash }}</td>
                        <td class="num">{{ f.dp|num_dash }}</td>
                        <td class="num">{{ f.tp|num_dash }}</td>
                        <td class="num">{{ f.range_factor_game|num_dash }}</td>
                        <td class="num">{{ f.range_factor_9|num_dash }}</td>
                        <td class="num">{{ f.throwing_errors|num_dash }}</td>
                    </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
    {% else %}
    <div class="glass-panel empty-season-msg">
        尚無守備數據
    </div>
    {% endif %}
</div>
