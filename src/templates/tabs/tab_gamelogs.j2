{# ── TAB 3: GAME LOGS ── #}
<div class="tab-panel" id="panel-gamelogs">

    {# Year + Level filter #}
    <div class="log-filter-bar">
        <label class="filter-label" for="gamelog-year-select">年度</label>
        <select id="gamelog-year-select" class="filter-select">
            {% for y in available_log_years %}
            <option value="{{ y }}"{% if loop.first %} selected{% endif %}>{{ y }}</option>
            {% else %}
            <option value="{{ selected_year }}" selected>{{ selected_year }}</option>
            {% endfor %}
        </select>
        <label class="filter-label" for="gamelog-level-select">層級</label>
        <select id="gamelog-level-select" class="filter-select"></select>
    </div>

    {% for y in available_log_years %}
    {% set year_logs = logs_by_year[y] %}
    <div class="gamelog-table-container data-table-section glass-panel" id="gamelogs-{{ y }}" {% if not loop.first %}style="display: none;"{% endif %}>
        <h3>{{ y }} 逐場比賽紀錄</h3>
        <div class="table-scroll">
            <table class="data-table">
                <thead>
                    <tr>
                        <th>日期</th><th>主/客</th><th>對手</th>
                        {% if is_pitcher %}
                            <th data-tooltip="投球局數">IP</th><th data-tooltip="被安打數">H</th><th data-tooltip="被得分數">R</th><th data-tooltip="被自責分數">ER</th><th data-tooltip="四壞球數">BB</th><th data-tooltip="三振數">SO</th><th data-tooltip="被全壘打數">HR</th><th data-tooltip="投出觸身球數">HB</th><th data-tooltip="當賽季累計防禦率">ERA</th><th data-tooltip="勝敗、救援或中繼結果">結果</th>
                        {% else %}
                            <th data-tooltip="打數">AB</th><th data-tooltip="得分數">R</th><th data-tooltip="安打數">H</th><th data-tooltip="二壘安打數">2B</th><th data-tooltip="三壘安打數">3B</th><th data-tooltip="全壘打數">HR</th><th data-tooltip="打點數">RBI</th><th data-tooltip="四壞球數">BB</th><th data-tooltip="三振數">K</th><th data-tooltip="盜壘成功數">SB</th><th data-tooltip="盜壘失敗數">CS</th><th data-tooltip="當賽季累計打擊率">AVG</th><th data-tooltip="當賽季累計 OBP+SLG">OPS</th>
                        {% endif %}
                    </tr>
                </thead>
                <tbody>
                    {% for log in year_logs %}
                    <tr class="gamelog-data-row{% if log.pitch_data_url %} game-row-expandable{% endif %}"
                        data-level="{{ log.sport_level | level_display(y) }}"
                        {% if log.pitch_data_url %}onclick="togglePitchLog('pitchlog-{{ y }}-{{ loop.index }}')" style="cursor:pointer;"{% endif %}>
                        <td>
                            {% if log.pitch_data_url %}<span class="toggle-arrow pitch-arrow" id="arrow-pitchlog-{{ y }}-{{ loop.index }}"></span>{% endif %}
                            {{ log.date }}
                        </td>
                        <td><span class="ha-tag {% if log.is_home %}ha-home{% else %}ha-away{% endif %}">
                            {% if log.is_home %}主{% else %}客{% endif %}
                        </span></td>
                        <td>{{ log.opponent }}</td>
                        {% set s = log.stats_json %}
                        {% if is_pitcher %}
                            <td class="num">{{ s.inningsPitched|num_dash }}</td>
                            <td class="num">{{ s.hits|default_if_none("0") }}</td>
                            <td class="num">{{ s.runs|default_if_none("0") }}</td>
                            <td class="num">{{ s.earnedRuns|default_if_none("0") }}</td>
                            <td class="num">{{ s.baseOnBalls|default_if_none("0") }}</td>
                            <td class="num">{{ s.strikeOuts|default_if_none("0") }}</td>
                            <td class="num">{{ s.homeRuns|default_if_none("0") }}</td>
                            <td class="num">{{ s.hitByPitch|default_if_none("0") }}</td>
                            <td class="num">{{ s.era|num_dash }}</td>
                            <td>{% if s.wins %}W{% elif s.losses %}L{% elif s.saves %}S{% elif s.holds %}H{% else %}-{% endif %}</td>
                        {% else %}
                            <td class="num">{{ s.atBats|default_if_none("0") }}</td>
                            <td class="num">{{ s.runs|default_if_none("0") }}</td>
                            <td class="num">{{ s.hits|default_if_none("0") }}</td>
                            <td class="num">{{ s.doubles|default_if_none("0") }}</td>
                            <td class="num">{{ s.triples|default_if_none("0") }}</td>
                            <td class="num">{{ s.homeRuns|default_if_none("0") }}</td>
                            <td class="num">{{ s.rbi|default_if_none("0") }}</td>
                            <td class="num">{{ s.baseOnBalls|default_if_none("0") }}</td>
                            <td class="num">{{ s.strikeOuts|default_if_none("0") }}</td>
                            <td class="num">{{ s.stolenBases|default_if_none("0") }}</td>
                            <td class="num">{{ s.caughtStealing|default_if_none("0") }}</td>
                            <td class="num">{{ s.avg|num_dash }}</td>
                            <td class="num">{{ s.ops|num_dash }}</td>
                        {% endif %}
                    </tr>
                    {% if log.pitch_data_url %}
                    {# Pitch log: placeholder row; JSON is fetched on first expand. #}
                    <tr class="pitch-log-row" id="pitchlog-{{ y }}-{{ loop.index }}" data-src="{{ log.pitch_data_url }}" data-level="{{ log.sport_level | level_display(y) }}" style="display:none;">
                        <td colspan="{% if is_pitcher %}13{% else %}16{% endif %}" class="pitch-log-cell">
                            <div class="pitch-log-scroll" id="pitchlog-content-{{ y }}-{{ loop.index }}"></div>
                        </td>
                    </tr>
                    {% endif %}
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
    {% endfor %}
    
    {% if not available_log_years %}
    <div class="glass-panel empty-season-msg">
        {{ selected_year }} 尚無出賽紀錄
    </div>
    {% endif %}
</div>
