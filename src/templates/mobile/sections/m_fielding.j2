<section class="m-section-stack" aria-label="守備數據">
    {% if all_fielding %}
    <div class="m-table-card data-table-section glass-panel">
        <h3>歷年守備數據</h3>
        <div class="table-scroll m-table-scroll">
            <table class="data-table m-sticky-table">
                <thead>
                    <tr>
                        <th>年度</th><th>層級</th><th>球隊</th><th>POS</th><th>GP</th><th>GS</th><th>INN</th><th>TC</th><th>PO</th><th>A</th><th>E</th><th>FLD%</th><th>DP</th><th>RF/G</th><th>RF/9</th>
                    </tr>
                </thead>
                <tbody>
                    {% for f in all_fielding %}
                    <tr class="{% if f.year == selected_year %}highlight-row{% endif %}">
                        <td>{{ f.year }}</td><td><span class="level-tag level-{{ f.sport_level|lower }}">{{ f.sport_level }}</span></td><td>{{ f.team_name }}</td><td><span class="pos-tag">{{ f.position }}</span></td><td class="num">{{ f.gp|num_dash }}</td><td class="num">{{ f.gs|num_dash }}</td><td class="num">{{ f.innings|num_dash }}</td><td class="num">{{ f.chances|num_dash }}</td><td class="num">{{ f.putouts|num_dash }}</td><td class="num">{{ f.assists|num_dash }}</td><td class="num">{{ f.errors|num_dash }}</td><td class="num">{{ f.fielding_pct|num_dash }}</td><td class="num">{{ f.dp|num_dash }}</td><td class="num">{{ f.range_factor_game|num_dash }}</td><td class="num">{{ f.range_factor_9|num_dash }}</td>
                    </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
    {% else %}
    <div class="glass-panel empty-season-msg">尚無守備數據</div>
    {% endif %}
</section>