<section class="m-hero glass-panel" aria-label="球員摘要">
    <div class="m-hero-photo">
        <div class="m-hero-avatar">
            {# 頭像：先試 CDN primary，fallback 至 secondary，最後顯示文字縮寫（見 avatar-fallback.js）#}
            {% set cdn_primary, cdn_secondary = headshot_cdn_urls(player.mlb_id, player.latest_level_is_mlb) %}
            <img src="{{ cdn_primary }}" data-cdn-src="{{ cdn_secondary }}" alt="{{ player_name }}" class="avatar-img">
            <div class="avatar-initials avatar-fallback" aria-hidden="true">{{ player.name_en[:1] }}</div>
        </div>
    </div>

    <div class="m-hero-info">
        <h1>{{ player.name_tw or player.name_en }}</h1>
        <span class="m-hero-name-en">{{ player.name_en }}</span>
        <div class="m-hero-meta">
            <span class="badge {{ 'badge-mlb' if is_mlb(player.level) else 'badge-level' }}">{{ player.level | level_display(player.latest_stat.year if player.latest_stat else none) }}</span>
            <span>{{ player.team }}</span>
            <span>{% if is_pitcher %}{{ (player.pitch_hand or "R") }}HP{% else %}{{ (player.bat_side or "?")[:1] }}{% endif %} · {{ player.position }}</span>
        </div>
    </div>

    {% if latest_team_stat %}
    {% set stat = latest_team_stat %}
    <div class="m-hero-stats" aria-label="關鍵數據">
        {% if is_pitcher %}
            <div class="m-hero-stat"><span>{{ stat.era|floatformat(2) }}</span><b>ERA</b></div>
            <div class="m-hero-stat"><span>{{ stat.whip|floatformat(2) }}</span><b>WHIP</b></div>
            <div class="m-hero-stat"><span>{{ stat.so|num_dash }}</span><b>K</b></div>
            <div class="m-hero-stat"><span>{{ stat.wins|num_dash }}-{{ stat.losses|num_dash }}</span><b>W-L</b></div>
            <div class="m-hero-stat"><span>{{ stat.ip|floatformat(1) }}</span><b>IP</b></div>
        {% else %}
            <div class="m-hero-stat"><span>{{ stat.avg|floatformat(3) }}</span><b>AVG</b></div>
            <div class="m-hero-stat"><span>{{ stat.ops|floatformat(3) }}</span><b>OPS</b></div>
            <div class="m-hero-stat"><span>{{ stat.hr|num_dash }}</span><b>HR</b></div>
            <div class="m-hero-stat"><span>{{ stat.rbi|num_dash }}</span><b>RBI</b></div>
            <div class="m-hero-stat"><span>{{ stat.sb|num_dash }}</span><b>SB</b></div>
        {% endif %}
    </div>
    {% endif %}
</section>
