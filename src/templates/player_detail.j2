{% extends 'base.j2' %}

{% block content %}

<div class="page-desktop">
{% set player_name = player.name_tw ~ ' ' ~ player.name_en if player.name_tw else player.name_en %}

{# ── TAB SYSTEM (JS-based for performance) ── #}

{# ── PLAYER HERO ── #}
<div class="profile-hero glass-panel" id="player-hero-{{ player.mlb_id }}">
    <div class="hero-photo-wrap">
        <div class="hero-avatar" id="avatar-{{ player.mlb_id }}">
            <img
                src="{{ base_url }}img/players/{{ player.mlb_id }}.jpg"
                data-cdn-src="https://img.mlbstatic.com/mlb-photos/image/upload/w_180,q_auto:best/v1/people/{{ player.mlb_id }}/headshot/milb/current"
                alt="{{ player_name }}"
                id="headshot-{{ player.mlb_id }}"
                class="avatar-img"
            >
            <div class="avatar-initials avatar-fallback" id="initials-{{ player.mlb_id }}" aria-hidden="true">
                {{ player.name_en[:1] }}
            </div>
        </div>
    </div>

    <div class="hero-info">
        <h1>{{ player.name_tw or player.name_en }}
            <span class="hero-name-en">{{ player.name_en }}</span>
        </h1>
        <div class="hero-meta">
            <span class="badge {{ 'badge-mlb' if player.level == 'MLB' else 'badge-level' }}">{{ player.level }}</span>
            <span class="hero-team">{{ player.team }}</span>
            <span class="hero-pos">{% if is_pitcher %}{{ (player.pitch_hand or "R") }}HP{% else %}{{ (player.bat_side or "?")[:1] }}{% endif %} · {{ player.position }}</span>
        </div>
    </div>

    {# ── KEY STATS STRIP ── #}
    {% if latest_team_stat %}
    {% set stat = latest_team_stat %}
    <div class="hero-stats-strip">
        {% if is_pitcher %}
            <div class="hs-item"><span class="hs-val">{{ stat.era|floatformat(2) }}</span><span class="hs-lbl">ERA</span></div>
            <div class="hs-item"><span class="hs-val">{{ stat.whip|floatformat(2) }}</span><span class="hs-lbl">WHIP</span></div>
            <div class="hs-item"><span class="hs-val">{{ stat.so|num_dash }}</span><span class="hs-lbl">K</span></div>
            <div class="hs-item"><span class="hs-val">{{ stat.wins|num_dash }}-{{ stat.losses|num_dash }}</span><span class="hs-lbl">W-L</span></div>
            <div class="hs-item"><span class="hs-val">{{ stat.ip|floatformat(1) }}</span><span class="hs-lbl">IP</span></div>
        {% else %}
            <div class="hs-item"><span class="hs-val">{{ stat.avg|floatformat(3) }}</span><span class="hs-lbl">AVG</span></div>
            <div class="hs-item"><span class="hs-val">{{ stat.ops|floatformat(3) }}</span><span class="hs-lbl">OPS</span></div>
            <div class="hs-item"><span class="hs-val">{{ stat.hr|num_dash }}</span><span class="hs-lbl">HR</span></div>
            <div class="hs-item"><span class="hs-val">{{ stat.rbi|num_dash }}</span><span class="hs-lbl">RBI</span></div>
            <div class="hs-item"><span class="hs-val">{{ stat.sb|num_dash }}</span><span class="hs-lbl">SB</span></div>
        {% endif %}
    </div>
    {% endif %}
</div>

{# ── TAB NAV ── #}
<div class="tab-nav glass-panel">
    <label data-tab="bio" class="tab-label tab-label--active">球員資料</label>
    <label data-tab="stats" class="tab-label">基礎數據</label>
    <label data-tab="gamelogs" class="tab-label">比賽紀錄</label>
    <label data-tab="advanced" class="tab-label">進階數據</label>
    <label data-tab="fielding" class="tab-label">守備數據</label>
    <label data-tab="plot" class="tab-label">數據圖表</label>
</div>

{% include 'tabs/tab_bio.j2' %}
{% include 'tabs/tab_stats.j2' %}
{% include 'tabs/tab_gamelogs.j2' %}
{% include 'tabs/tab_advanced.j2' %}
{% include 'tabs/tab_fielding.j2' %}
{% include 'tabs/tab_plot.j2' %}

</div>

<div class="page-mobile">
    {% include 'mobile/m_player_detail.j2' %}
</div>
{% endblock %}

{% block extra_scripts %}
<script src="{{ static_url('js/stats-table.js') }}"></script>
<script src="{{ static_url('js/stats-tooltip.js') }}"></script>
<script src="{{ static_url('js/pitch-log.js') }}"></script>
<script src="{{ static_url('js/gamelogs.js') }}"></script>
<script src="{{ static_url('js/mobile/m-pitch-log.js') }}"></script>
<script src="{{ static_url('js/mobile/m-gamelogs.js') }}"></script>
<script src="{{ static_url('js/arsenal-filters.js') }}"></script>
<script src="{{ static_url('js/mobile/m-advanced.js') }}"></script>
<script src="{{ static_url('js/pitcher-charts.js') }}"></script>
<script src="{{ static_url('js/pitch-plinko.js') }}"></script>
{% if chart_data %}
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script type="application/json" id="chart-labels">{{ chart_labels|tojson_safe }}</script>
<script type="application/json" id="chart-data">{{ chart_data|tojson_safe }}</script>
<script src="{{ static_url('js/charts.js') }}"></script>
{% endif %}
<script src="{{ static_url('js/mobile/m-charts.js') }}"></script>
<script src="{{ static_url('js/tabs.js') }}"></script>
{% endblock %}
