<section class="m-section-stack" aria-label="球員資料">
    <div class="m-card glass-panel">
        <div class="m-card-title">個人資料</div>
        <dl class="m-bio-dl">
            {% if player.birth_date %}
            <dt>出生日期</dt><dd>{{ player.birth_date }}{% if player.age %} ({{ player.age }}歲){% endif %}</dd>
            {% endif %}
            {% if player.birth_city or player.birth_country %}
            <dt>出生地</dt><dd>{{ player.birth_city }}{% if player.birth_city and player.birth_country %}, {% endif %}{{ player.birth_country }}</dd>
            {% endif %}
            {% if player.height %}
            <dt>身高</dt><dd>{{ player.height }}{% if height_cm %} ({{ height_cm }} cm){% endif %}</dd>
            {% endif %}
            {% if player.weight %}
            <dt>體重</dt><dd>{{ player.weight }} lbs{% if weight_kg %} ({{ weight_kg }} kg){% endif %}</dd>
            {% endif %}
            {% if player.bat_side %}<dt>打擊方向</dt><dd>{{ player.bat_side }}</dd>{% endif %}
            {% if player.pitch_hand %}<dt>投球手</dt><dd>{{ player.pitch_hand }}</dd>{% endif %}
            <dt>狀態</dt>
            <dd><span class="status-pill {{ player.status_category }}">{{ player.status_display }}</span></dd>
        </dl>
    </div>

    <div class="m-card glass-panel">
        <div class="m-card-title">下場比賽</div>
        {% if next_game %}
        <div class="m-next-game">
            <div class="m-next-game-matchup">
                <span>{% if next_game.is_home %}vs{% else %}@{% endif %}</span>
                <strong>{{ next_game.opponent }}</strong>
            </div>
            <div class="m-next-game-meta">
                <span>{{ next_game.game_time }}</span>
                {% if next_game.venue %}<span>{{ next_game.venue }}</span>{% endif %}
            </div>
        </div>
        {% else %}
        <p class="m-empty-text">近期無賽程資料</p>
        {% endif %}
    </div>

    {% if total_career or season_combined %}
    <div class="m-card glass-panel">
        <div class="m-card-title">生涯與本季數據</div>
        <div class="m-career-stack">
            {% if total_career %}
            <section>
                <h3>生涯累計 ({{ total_career.years_range }})</h3>
                {% if is_pitcher %}
                <div class="m-bio-stats-strip">
                    <div class="m-bio-stat"><span>{{ total_career.gp|num_dash }}</span><b>G</b></div>
                    <div class="m-bio-stat"><span>{{ total_career.era|floatformat(2) }}</span><b>ERA</b></div>
                    <div class="m-bio-stat"><span>{{ total_career.whip|floatformat(2) }}</span><b>WHIP</b></div>
                    <div class="m-bio-stat"><span>{{ total_career.so|num_dash }}</span><b>K</b></div>
                    <div class="m-bio-stat"><span>{{ total_career.wins|num_dash }}-{{ total_career.losses|num_dash }}</span><b>W-L</b></div>
                    <div class="m-bio-stat"><span>{{ total_career.ip|floatformat(1) if total_career.ip else '-' }}</span><b>IP</b></div>
                </div>
                {% else %}
                <div class="m-bio-stats-strip">
                    <div class="m-bio-stat"><span>{{ total_career.gp|num_dash }}</span><b>G</b></div>
                    <div class="m-bio-stat"><span>{{ total_career.avg|floatformat(3) }}</span><b>AVG</b></div>
                    <div class="m-bio-stat"><span>{{ total_career.ops|floatformat(3) }}</span><b>OPS</b></div>
                    <div class="m-bio-stat"><span>{{ total_career.hr|num_dash }}</span><b>HR</b></div>
                    <div class="m-bio-stat"><span>{{ total_career.rbi|num_dash }}</span><b>RBI</b></div>
                    <div class="m-bio-stat"><span>{{ total_career.sb|num_dash }}</span><b>SB</b></div>
                </div>
                {% endif %}
            </section>
            {% endif %}
            {% if season_combined %}
            {% set sc = season_combined %}
            <section>
                <h3>{{ sc.year }} 賽季 — {{ sc.teams_display }}</h3>
                {% if is_pitcher %}
                <div class="m-bio-stats-strip">
                    <div class="m-bio-stat"><span>{{ sc.gp|num_dash }}</span><b>G</b></div>
                    <div class="m-bio-stat"><span>{{ sc.era|floatformat(2) }}</span><b>ERA</b></div>
                    <div class="m-bio-stat"><span>{{ sc.whip|floatformat(2) }}</span><b>WHIP</b></div>
                    <div class="m-bio-stat"><span>{{ sc.so|num_dash }}</span><b>K</b></div>
                    <div class="m-bio-stat"><span>{{ sc.wins|num_dash }}-{{ sc.losses|num_dash }}</span><b>W-L</b></div>
                    <div class="m-bio-stat"><span>{{ sc.ip|floatformat(1) if sc.ip else '-' }}</span><b>IP</b></div>
                </div>
                {% else %}
                <div class="m-bio-stats-strip">
                    <div class="m-bio-stat"><span>{{ sc.gp|num_dash }}</span><b>G</b></div>
                    <div class="m-bio-stat"><span>{{ sc.avg|floatformat(3) }}</span><b>AVG</b></div>
                    <div class="m-bio-stat"><span>{{ sc.ops|floatformat(3) }}</span><b>OPS</b></div>
                    <div class="m-bio-stat"><span>{{ sc.hr|num_dash }}</span><b>HR</b></div>
                    <div class="m-bio-stat"><span>{{ sc.rbi|num_dash }}</span><b>RBI</b></div>
                    <div class="m-bio-stat"><span>{{ sc.sb|num_dash }}</span><b>SB</b></div>
                </div>
                {% endif %}
            </section>
            {% endif %}
        </div>
    </div>
    {% endif %}

    {% if transactions or player.latest_transaction %}
    <div class="m-card glass-panel">
        <div class="m-card-title">異動紀錄{% if transactions %}<span>{{ transactions|length }}</span>{% endif %}</div>
        {% if transactions %}
        <div class="m-timeline" data-m-timeline>
            {% for tx in transactions %}
            <article class="m-timeline-item{% if loop.index > 3 %} m-timeline-extra{% endif %}">
                <div class="m-timeline-meta">
                    <time>{{ tx.date }}</time>
                    {% if tx.type %}<span>{{ tx.type }}</span>{% endif %}
                </div>
                <p>{{ tx.description }}</p>
            </article>
            {% endfor %}
        </div>
        {% if transactions|length > 3 %}
        <button class="m-show-more" data-m-show-more type="button">顯示更多</button>
        {% endif %}
        {% else %}
        <p class="m-empty-text">{{ player.latest_transaction }}</p>
        {% endif %}
    </div>
    {% endif %}

</section>