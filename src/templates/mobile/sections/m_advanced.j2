{# ── 手機版 TAB：進階數據（統一 mc-* 數據卡片系統）── #}
{% macro mcell(label, value) -%}
<div class="mc-cell"><b>{{ label }}</b><span>{{ value }}</span></div>
{%- endmacro %}

{# 歷年進階數據：單筆成績卡片內容（summary 或單一球隊明細共用） #}
{% macro adv_body(s) %}
    {% if is_pitcher %}
    <div class="mc-hero">
        <div class="mc-hero-cell"><span>{{ s.whip|floatformat(2) }}</span><b>WHIP</b></div>
        <div class="mc-hero-cell"><span>{{ s.k_per_9|floatformat(1) }}</span><b>K/9</b></div>
        <div class="mc-hero-cell"><span>{{ s.bb_per_9|floatformat(1) }}</span><b>BB/9</b></div>
        <div class="mc-hero-cell"><span>{{ s.k_bb_ratio|floatformat(2) }}</span><b>K/BB</b></div>
    </div>
    <div class="mc-grid">
        {{ mcell('H/9', s.h_per_9|floatformat(1)) }}
        {{ mcell('HR/9', s.hr_per_9|floatformat(2)) }}
        {{ mcell('K%', s.p_k_pct|pct_fmt) }}
        {{ mcell('BB%', s.p_bb_pct|pct_fmt) }}
        {{ mcell('Strike%', s.strike_pct|num_dash) }}
        {{ mcell('AVG', s.p_avg|num_dash) }}
        {{ mcell('OBP', s.p_obp|num_dash) }}
        {{ mcell('SLG', s.p_slg|num_dash) }}
        {{ mcell('OPS', s.p_ops|num_dash) }}
        {{ mcell('BABIP', s.p_babip|floatformat(3)) }}
        {{ mcell('GO/AO', s.p_go_ao|floatformat(2)) }}
        {{ mcell('P/PA', s.pitches_per_pa|floatformat(2)) }}
    </div>
    {% else %}
    <div class="mc-hero">
        <div class="mc-hero-cell"><span>{{ s.k_pct|pct_fmt }}</span><b>K%</b></div>
        <div class="mc-hero-cell"><span>{{ s.bb_pct|pct_fmt }}</span><b>BB%</b></div>
        <div class="mc-hero-cell"><span>{{ s.iso|floatformat(3) }}</span><b>ISO</b></div>
        <div class="mc-hero-cell"><span>{{ s.babip|floatformat(3) }}</span><b>BABIP</b></div>
    </div>
    <div class="mc-grid">
        {{ mcell('XBH', s.xbh|num_dash) }}
        {{ mcell('AB/HR', s.ab_per_hr|floatformat(1)) }}
        {{ mcell('GO/AO', s.go_ao|floatformat(2)) }}
        {{ mcell('SB%', s.sb_pct|num_dash) }}
        {{ mcell('P/PA', s.p_per_pa|floatformat(2)) }}
        {{ mcell('IBB', s.ibb|num_dash) }}
        {{ mcell('HBP', s.hbp|num_dash) }}
        {{ mcell('GIDP', s.gdp|num_dash) }}
        {{ mcell('GIDPO', s.gidpo|num_dash) }}
        {{ mcell('SF', s.sac_flies|num_dash) }}
        {{ mcell('SH', s.sac_bunts|num_dash) }}
        {{ mcell('LOB', s.lob|num_dash) }}
        {{ mcell('ROE', s.roe|num_dash) }}
        {{ mcell('WO', s.wo|num_dash) }}
    </div>
    {% endif %}
{% endmacro %}

<section class="m-section-stack" aria-label="進階數據">

    {# ════ 歷年進階數據 ════ #}
    <div class="glass-panel m-data-sec">
        <h3>歷年進階數據</h3>
        {% if stats_year_groups %}
        <div class="mc-list">
            {% for grp in stats_year_groups %}
            {% set yr = grp.year %}
            <article class="mc-card">
                <header class="mc-hd{% if grp.multi %} mc-hd--tap{% endif %}"
                    {% if grp.multi %}onclick="toggleMobileYearGroup('adv','{{ yr }}')"{% endif %}>
                    <div class="mc-hd-meta">
                        <span class="mc-yr">{{ yr }}</span>
                        {% if grp.multi %}
                        <span class="multi-tag">{{ grp.rows|length }} 隊合計</span>
                        {% else %}
                        <span class="level-tag">{{ grp.rows[0].sport_level | level_display(grp.rows[0].year) }}</span>
                        <span class="mc-team">{{ grp.rows[0].team_name }}</span>
                        {% endif %}
                    </div>
                    {% if grp.multi %}
                    <div class="mc-hd-aside"><span class="toggle-arrow" id="m-arrow-adv-{{ yr }}"></span></div>
                    {% endif %}
                </header>

                {{ adv_body(grp.summary) }}

                {% if grp.multi %}
                <div class="mc-sub-list" id="m-subdetail-adv-{{ yr }}" style="display:none;">
                    {% for stat in grp.rows %}
                    <div class="mc-sub-card">
                        <div class="mc-sub-hd">
                            <span class="level-tag">{{ stat.sport_level | level_display(stat.year) }}</span>
                            <span class="mc-team">{{ stat.team_name }}</span>
                        </div>
                        {{ adv_body(stat) }}
                    </div>
                    {% endfor %}
                </div>
                {% endif %}
            </article>
            {% endfor %}
        </div>
        {% else %}
        <p class="m-empty-text">尚無數據</p>
        {% endif %}
    </div>

    {% if statcast_available %}

    {# ════ Statcast 概覽 ════ #}
    <div class="glass-panel m-data-sec">
        <h3>Statcast 概覽</h3>
        <div class="mc-list">
            {% for yr in available_statcast_years %}
            {% set entries = statcast_by_year[yr] %}
            {% set level_entries = entries if entries|length == 1 else entries[1:] %}
            {% for entry in level_entries %}
            {% set sc = entry.sc %}
            {% set ss_row = entry.stat %}
            <article class="mc-card">
                <header class="mc-hd">
                    <div class="mc-hd-meta">
                        <span class="mc-yr">{{ yr }}</span>
                        <span class="level-tag">{{ entry.sport_level | level_display(yr) }}</span>
                    </div>
                </header>
                {% if is_pitcher %}
                <div class="mc-hero">
                    <div class="mc-hero-cell"><span>{% if ss_row and ss_row.fip %}{{ ss_row.fip|floatformat(2) }}{% else %}—{% endif %}</span><b>FIP</b></div>
                    <div class="mc-hero-cell"><span>{{ sc.woba_against|floatformat(3) }}</span><b>wOBA</b></div>
                    <div class="mc-hero-cell"><span>{% if ss_row and ss_row.expected and ss_row.expected.xwoba %}{{ ss_row.expected.xwoba|floatformat(3) }}{% else %}—{% endif %}</span><b>xwOBA</b></div>
                    <div class="mc-hero-cell"><span>{% if ss_row and ss_row.xwpct %}{{ ss_row.xwpct|floatformat(3) }}{% else %}—{% endif %}</span><b>xWPCT</b></div>
                </div>
                <div class="mc-grid">
                    {{ mcell('Barrel%', sc.barrel_pct|pct_fmt) }}
                    {{ mcell('Hard-Hit%', sc.hard_hit_pct|pct_fmt) }}
                    {{ mcell('Avg EV', sc.avg_ev|floatformat(1)) }}
                    {{ mcell('GB%', sc.gb_pct|pct_fmt) }}
                    {{ mcell('HR/FB%', sc.hr_fb_pct|pct_fmt) }}
                    {{ mcell('Whiff%', sc.whiff_pct|pct_fmt) }}
                    {{ mcell('Avg Ext', sc.avg_extension|floatformat(2)) }}
                </div>
                {% else %}
                <div class="mc-hero">
                    <div class="mc-hero-cell"><span>{{ sc.woba|floatformat(3) }}</span><b>wOBA</b></div>
                    <div class="mc-hero-cell"><span>{% if ss_row and ss_row.expected and ss_row.expected.xwoba %}{{ ss_row.expected.xwoba|floatformat(3) }}{% else %}—{% endif %}</span><b>xwOBA</b></div>
                    <div class="mc-hero-cell"><span>{% if ss_row and ss_row.wrc_plus is not none %}{{ ss_row.wrc_plus }}{% else %}—{% endif %}</span><b>wRC+</b></div>
                    <div class="mc-hero-cell"><span>{% if ss_row and ss_row.war %}{{ ss_row.war|floatformat(1) }}{% else %}—{% endif %}</span><b>WAR</b></div>
                </div>
                <div class="mc-grid">
                    {{ mcell('BBE', sc.bbe|num_dash) }}
                    {{ mcell('Barrel%', sc.barrel_pct|pct_fmt) }}
                    {{ mcell('Hard-Hit%', sc.hard_hit_pct|pct_fmt) }}
                    {{ mcell('Avg EV', sc.avg_ev|floatformat(1)) }}
                    {{ mcell('Max EV', sc.max_ev|floatformat(1)) }}
                    {{ mcell('EV90', sc.ev90|floatformat(1)) }}
                    {{ mcell('Avg LA', sc.avg_la|floatformat(1)) }}
                    {{ mcell('SwSp%', sc.swsp_pct|pct_fmt) }}
                </div>
                {% endif %}
            </article>
            {% endfor %}
            {% endfor %}
        </div>
    </div>

    {# ════ Plate Discipline ════ #}
    <div class="glass-panel m-data-sec">
        <h3>Plate Discipline</h3>
        <div class="mc-list">
            {% for yr in available_statcast_years %}
            {% set entries = statcast_by_year[yr] %}
            {% set level_entries = entries if entries|length == 1 else entries[1:] %}
            {% for entry in level_entries %}
            {% set sc = entry.sc %}
            <article class="mc-card">
                <header class="mc-hd">
                    <div class="mc-hd-meta">
                        <span class="mc-yr">{{ yr }}</span>
                        <span class="level-tag">{{ entry.sport_level | level_display(yr) }}</span>
                    </div>
                    <div class="mc-hd-aside">
                        <span class="mc-meta">{{ sc.total_pitches|num_dash }} Pitches</span>
                    </div>
                </header>
                <div class="mc-hero">
                    <div class="mc-hero-cell"><span>{{ sc.zone_pct|pct_fmt }}</span><b>Zone%</b></div>
                    <div class="mc-hero-cell"><span>{{ sc.whiff_pct|pct_fmt }}</span><b>Whiff%</b></div>
                    <div class="mc-hero-cell"><span>{{ sc.csw_pct|pct_fmt }}</span><b>CSW%</b></div>
                    <div class="mc-hero-cell"><span>{{ sc.swstr_pct|pct_fmt }}</span><b>SwStr%</b></div>
                </div>
                <div class="mc-grid">
                    {% if not is_pitcher %}{{ mcell('Strike%', sc.strike_pct|pct_fmt) }}{% endif %}
                    {{ mcell('Z-Swing%', sc.z_swing_pct|pct_fmt) }}
                    {{ mcell('O-Swing%', sc.o_swing_pct|pct_fmt) }}
                    {{ mcell('Z-Contact%', sc.z_contact_pct|pct_fmt) }}
                    {{ mcell('Swing%', sc.swing_pct|pct_fmt) }}
                </div>
            </article>
            {% endfor %}
            {% endfor %}
        </div>
    </div>

    {# ════ 擊球型態 ════ #}
    <div class="glass-panel m-data-sec">
        <h3>擊球型態</h3>
        <div class="mc-list">
            {% for yr in available_statcast_years %}
            {% set entries = statcast_by_year[yr] %}
            {% set level_entries = entries if entries|length == 1 else entries[1:] %}
            {% for entry in level_entries %}
            {% set sc = entry.sc %}
            {% if sc.bbe is not none %}
            <article class="mc-card">
                <header class="mc-hd">
                    <div class="mc-hd-meta">
                        <span class="mc-yr">{{ yr }}</span>
                        <span class="level-tag">{{ entry.sport_level | level_display(yr) }}</span>
                    </div>
                    <div class="mc-hd-aside">
                        <span class="mc-meta">{{ sc.bbe|num_dash }} BBE</span>
                    </div>
                </header>
                <div class="mc-hero">
                    <div class="mc-hero-cell"><span>{{ sc.gb_pct|pct_fmt }}</span><b>GB%</b></div>
                    <div class="mc-hero-cell"><span>{{ sc.ld_pct|pct_fmt }}</span><b>LD%</b></div>
                    <div class="mc-hero-cell"><span>{{ sc.fb_pct|pct_fmt }}</span><b>FB%</b></div>
                    <div class="mc-hero-cell"><span>{{ sc.pu_pct|pct_fmt }}</span><b>PU%</b></div>
                </div>
                <div class="mc-grid">
                    {{ mcell('Air%', sc.air_pct|pct_fmt) }}
                    {{ mcell('Pull%', sc.pull_pct|pct_fmt) }}
                    {{ mcell('Straight%', sc.straight_pct|pct_fmt) }}
                    {{ mcell('Oppo%', sc.oppo_pct|pct_fmt) }}
                    {% if not is_pitcher %}{{ mcell('PullAir%', sc.pull_air_pct|pct_fmt) }}{% endif %}
                </div>
            </article>
            {% endif %}
            {% endfor %}
            {% endfor %}
        </div>
    </div>

    {# ════ 球種分析 ════ #}
    <div class="glass-panel m-data-sec">
        <h3>{% if is_pitcher %}投球球種分析{% else %}對戰球種分析{% endif %}</h3>

        <div class="m-filter-bar m-filter-bar--inset">
            <label class="filter-label" for="m-arsenal-year-select">年度</label>
            <select id="m-arsenal-year-select" class="filter-select">
                {% for yr in available_statcast_years %}
                <option value="{{ yr }}"{% if loop.first %} selected{% endif %}>{{ yr }}</option>
                {% endfor %}
            </select>
            <label class="filter-label" for="m-arsenal-level-select">層級</label>
            <select id="m-arsenal-level-select" class="filter-select"></select>
            {% if is_pitcher %}
            <label class="filter-label" for="m-arsenal-bat-side-select">對戰打者</label>
            <select id="m-arsenal-bat-side-select" class="filter-select">
                <option value="all" selected>全部</option>
                <option value="L">左打</option>
                <option value="R">右打</option>
            </select>
            {% endif %}
        </div>

        {% for yr in available_statcast_years %}
        {% set _entries = statcast_by_year[yr] %}
        <div class="arsenal-table-container" id="m-arsenal-{{ yr }}" {% if not loop.first %}style="display: none;"{% endif %}>
            {% for _e in _entries %}
            {% set sc = _e.sc %}
            {% set _level = _e.sport_level %}
            <div class="arsenal-level-container" id="m-arsenal-{{ yr }}-{{ _level }}"
                 data-level="{{ _level | level_display(yr) }}"
                 data-level-label="{% if _level == '_combined' %}All Levels{% else %}{{ _level | level_display(yr) }}{% endif %}"
                 {% if not loop.first %}style="display: none;"{% endif %}>

                {% if is_pitcher %}
                {% set splits = sc.pitcher_bat_side_splits if sc.pitcher_bat_side_splits else {} %}
                {% for _side in ["all", "L", "R"] %}
                {% set split = splits.get(_side) if splits else none %}
                {% if not split and _side == "all" %}
                    {% set arsenal = sc.pitch_arsenal if sc.pitch_arsenal else [] %}
                    {% set outcomes = sc.pitch_outcomes if sc.pitch_outcomes else [] %}
                    {% set usage = sc.pitch_usage_by_count if sc.pitch_usage_by_count else {} %}
                {% else %}
                    {% set arsenal = split.pitch_arsenal if split and split.pitch_arsenal else [] %}
                    {% set outcomes = split.pitch_outcomes if split and split.pitch_outcomes else [] %}
                    {% set usage = split.pitch_usage_by_count if split and split.pitch_usage_by_count else {} %}
                {% endif %}
                {% set usage_types = usage.pitch_types if usage and usage.pitch_types else [] %}
                {% set usage_rows = usage.rows if usage and usage.rows else [] %}
                <div class="arsenal-split-container" data-bat-side="{{ _side }}" {% if not loop.first %}style="display: none;"{% endif %}>
                    {% if arsenal or outcomes or usage_types %}
                    <div class="mc-list">

                        {# ── 每個球種一張卡：特性 + 對戰結果 ── #}
                        {% set out_map = {} %}
                        {% for o in outcomes %}{% set _ = out_map.update({o.type: o}) %}{% endfor %}
                        {% set ars_map = {} %}
                        {% for a in arsenal %}{% set _ = ars_map.update({a.type: a}) %}{% endfor %}
                        {% for pt in (arsenal if arsenal else outcomes) %}
                        {% set a = ars_map.get(pt.type) %}
                        {% set o = out_map.get(pt.type) %}
                        <article class="mc-card">
                            <header class="mc-hd">
                                <div class="mc-hd-meta">
                                    <span class="pitch-tag pitch-{{ pt.type|lower }}">{{ pt.name or pt.type }}</span>
                                    {% if o %}<span class="mc-meta">{{ o.count|num_dash }} 球</span>{% endif %}
                                </div>
                                <div class="mc-hd-aside">
                                    <span class="m-pitch-usepct">{{ pt.pct|pct_fmt }}<b>使用率</b></span>
                                </div>
                            </header>
                            {% if a %}
                            <div class="mc-hero">
                                <div class="mc-hero-cell"><span>{{ a.velo|floatformat(1) }}</span><b>Velo</b></div>
                                <div class="mc-hero-cell"><span>{{ a.spin|num_dash }}</span><b>Spin</b></div>
                                <div class="mc-hero-cell"><span>{{ a.ivb|floatformat(1) }}</span><b>iVB</b></div>
                                <div class="mc-hero-cell"><span>{{ a.hb|floatformat(1) }}</span><b>HB</b></div>
                            </div>
                            <div class="mc-group-hd">出手與進壘</div>
                            <div class="mc-grid mc-grid--3">
                                {{ mcell('Ext.', a.extension|floatformat(2)) }}
                                {{ mcell('vRel', a.v_rel|floatformat(2)) }}
                                {{ mcell('hRel', a.h_rel|floatformat(2)) }}
                                {{ mcell('Zone%', a.zone_pct|pct_fmt) }}
                                {{ mcell('Chase%', a.chase_pct|pct_fmt) }}
                                {{ mcell('Whiff%', a.whiff_pct|pct_fmt) }}
                            </div>
                            {% endif %}
                            {% if o %}
                            <div class="mc-group-hd">對戰結果</div>
                            <div class="mc-grid">
                                {{ mcell('AVG', o.avg|floatformat(3)) }}
                                {{ mcell('wOBA', o.woba|floatformat(3)) }}
                                {{ mcell('Barrel%', o.barrel_pct|pct_fmt) }}
                                {{ mcell('HardHit%', o.hard_hit_pct|pct_fmt) }}
                                {{ mcell('Strike%', o.strike_pct|pct_fmt) }}
                                {{ mcell('Z-Whiff%', o.z_whiff_pct|pct_fmt) }}
                                {{ mcell('O-Swing%', o.o_swing_pct|pct_fmt) }}
                                {{ mcell('SwStr%', o.swstr_pct|pct_fmt) }}
                                {{ mcell('CSW%', o.csw_pct|pct_fmt) }}
                                {{ mcell('PutAway%', o.put_away_pct|pct_fmt) }}
                            </div>
                            {% endif %}
                        </article>
                        {% endfor %}

                        {# ── 各球數配球比例：堆疊色條 ── #}
                        {% if usage_types and usage_rows %}
                        <article class="mc-card">
                            <header class="mc-hd">
                                <div class="mc-hd-meta"><span class="mc-yr m-usage-title">各球數配球比例</span></div>
                            </header>
                            <div class="m-usage-legend">
                                {% for pitch in usage_types %}
                                <span class="pitch-tag pitch-{{ pitch.type|lower }}">{{ pitch.name or pitch.type }}</span>
                                {% endfor %}
                            </div>
                            <div class="m-usage">
                                {% for row in usage_rows %}
                                {% if row.key != 'all' %}
                                <div class="m-usage-row">
                                    <div class="m-usage-row-hd">
                                        <span class="m-usage-label">{{ row.label }}</span>
                                        <span class="m-usage-counts">{{ row.counts_label }}</span>
                                    </div>
                                    <div class="m-usage-bar">
                                        {% for pitch in usage_types %}
                                        {% set pitch_cell = namespace(pct=none) %}
                                        {% for pt in row.pitch_types %}
                                        {% if pt.type == pitch.type %}{% set pitch_cell.pct = pt.pct %}{% endif %}
                                        {% endfor %}
                                        {% if pitch_cell.pct %}
                                        <span class="m-useg pitch-{{ pitch.type|lower }}" style="width: {{ '%.2f'|format(pitch_cell.pct * 100) }}%;">
                                            {%- if pitch_cell.pct >= 0.16 %}{{ pitch.type }} {{ pitch_cell.pct|pct_fmt(0) }}{% endif -%}
                                        </span>
                                        {% endif %}
                                        {% endfor %}
                                    </div>
                                </div>
                                {% endif %}
                                {% endfor %}
                            </div>
                        </article>
                        {% endif %}

                    </div>
                    {% else %}
                    <div class="pitch-analysis-empty">無球種資料</div>
                    {% endif %}
                </div>
                {% endfor %}

                {% else %}
                {# ── 打者：對戰球種卡片 ── #}
                {% set vs = sc.vs_pitch_types if sc.vs_pitch_types else [] %}
                {% if vs %}
                <div class="mc-list">
                    {% for pt in vs %}
                    <article class="mc-card">
                        <header class="mc-hd">
                            <div class="mc-hd-meta">
                                <span class="pitch-tag pitch-{{ pt.type|lower }}">{{ pt.name or pt.type }}</span>
                            </div>
                            <div class="mc-hd-aside">
                                <span class="mc-meta">{{ pt.count|num_dash }} 球</span>
                            </div>
                        </header>
                        <div class="mc-hero">
                            <div class="mc-hero-cell"><span>{{ pt.avg|floatformat(3) }}</span><b>AVG</b></div>
                            <div class="mc-hero-cell"><span>{{ pt.woba|floatformat(3) }}</span><b>wOBA</b></div>
                            <div class="mc-hero-cell"><span>{{ pt.whiff_pct|pct_fmt }}</span><b>Whiff%</b></div>
                            <div class="mc-hero-cell"><span>{{ pt.hard_hit_pct|pct_fmt }}</span><b>Hard-Hit%</b></div>
                        </div>
                        <div class="mc-grid">
                            {{ mcell('Strike%', pt.strike_pct|pct_fmt) }}
                            {{ mcell('Zone%', pt.zone_pct|pct_fmt) }}
                            {{ mcell('Z-Swing%', pt.z_swing_pct|pct_fmt) }}
                            {{ mcell('O-Swing%', pt.o_swing_pct|pct_fmt) }}
                            {{ mcell('SwStr%', pt.swstr_pct|pct_fmt) }}
                            {{ mcell('CSW%', pt.csw_pct|pct_fmt) }}
                            {{ mcell('PutAway%', pt.put_away_pct|pct_fmt) }}
                            {{ mcell('Barrel%', pt.barrel_pct|pct_fmt) }}
                        </div>
                    </article>
                    {% endfor %}
                </div>
                {% else %}
                <div class="pitch-analysis-empty">尚無數據</div>
                {% endif %}
                {% endif %}
            </div>
            {% endfor %}
        </div>
        {% endfor %}
    </div>

    {% else %}
    <div class="glass-panel empty-season-msg">
        尚無 Statcast 數據
    </div>
    {% endif %}
</section>
