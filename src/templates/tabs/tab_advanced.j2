{# ── TAB 4: ADVANCED STATS ── #}
{% import "macros/table.j2" as macros %}
{% import "macros/tags.j2" as tags %}
<div class="tab-panel" id="panel-advanced">

    {# Advanced Stats Table #}
    <div class="data-table-section glass-panel">
        <h3>歷年進階數據</h3>
        <div class="table-scroll">
            <table class="data-table year-group-table" id="stats-table-adv">
                <thead>
                    <tr>
                        <th class="col-toggle"></th>
                        <th>年度</th><th>層級</th><th>球隊</th>
                        {% if is_pitcher %}
                            {{ macros.th('WHIP', '每局被上壘率：(H+BB) ÷ IP') }}{{ macros.th('K/9', '每9局三振數') }}{{ macros.th('BB/9', '每9局保送數') }}{{ macros.th('H/9', '每9局被安打數') }}{{ macros.th('HR/9', '每9局被全壘打數') }}{{ macros.th('K/BB', '三振保送比') }}
                            {{ macros.th('K%', '三振率：SO ÷ 面對打者數') }}{{ macros.th('BB%', '保送率：BB ÷ 面對打者數') }}{{ macros.th('Strike%', '好球率') }}
                            {{ macros.th('AVG', '被打擊率') }}{{ macros.th('OBP', '被上壘率') }}{{ macros.th('SLG', '被長打率') }}{{ macros.th('OPS', '被攻擊指數（OBP+SLG）') }}
                            {{ macros.th('BABIP', '場內打擊率（運氣指標，聯盟均約 .300）') }}{{ macros.th('GO/AO', '滾飛比，>1 為滾地球型') }}{{ macros.th('P/PA', '每打席用球數') }}
                        {% else %}
                            {{ macros.th('K%', '三振率：SO ÷ PA') }}{{ macros.th('BB%', '保送率：BB ÷ PA') }}
                            {{ macros.th('ISO', '純長打率：SLG − AVG') }}{{ macros.th('BABIP', '場內打擊率（運氣指標，聯盟均約 .300）') }}{{ macros.th('XBH', '長打數：2B+3B+HR') }}{{ macros.th('AB/HR', '每幾打數一支全壘打') }}{{ macros.th('GO/AO', '滾飛比') }}{{ macros.th('SB%', '盜壘成功率') }}
                            {{ macros.th('P/PA', '每打席面對球數') }}{{ macros.th('IBB', '故意四壞球數') }}{{ macros.th('HBP', '觸身球數') }}{{ macros.th('GIDP', '打成雙殺數') }}{{ macros.th('GIDPO', '雙殺機會數') }}
                            {{ macros.th('SF', '高飛犧牲打數') }}{{ macros.th('SH', '犧牲觸擊數') }}{{ macros.th('LOB', '殘壘數') }}{{ macros.th('ROE', '因失誤上壘數') }}{{ macros.th('WO', '再見安打數') }}
                        {% endif %}
                    </tr>
                </thead>
                <tbody>
                    {% for grp in stats_year_groups %}
                    {% set yr = grp.year %}
                    {% set sm = grp.summary %}
                    {# ── Summary row ── #}
                    <tr class="year-summary-row {% if yr == selected_year %}highlight-row{% endif %}"
                        data-year="{{ yr }}"
                        {% if grp.multi %}onclick="toggleYearGroup('adv','{{ yr }}')" style="cursor:pointer;"{% endif %}>
                        <td class="col-toggle">
                            {% if grp.multi %}<span class="toggle-arrow" id="arrow-adv-{{ yr }}"></span>{% endif %}
                        </td>
                        <td><strong>{{ yr }}</strong></td>
                        <td>{% if grp.multi %}<span class="multi-tag">合計</span>{% else %}{{ tags.level_tag(grp.rows[0].sport_level, grp.rows[0].year) }}{% endif %}</td>
                        <td>{% if not grp.multi %}{{ grp.rows[0].team_name }}{% else %}—{% endif %}</td>
                        {% if is_pitcher %}
                            <td class="num">{{ sm.whip|floatformat(2) }}</td>
                            <td class="num">{{ sm.k_per_9|floatformat(1) }}</td>
                            <td class="num">{{ sm.bb_per_9|floatformat(1) }}</td>
                            <td class="num">{{ sm.h_per_9|floatformat(1) }}</td>
                            <td class="num">{{ sm.hr_per_9|floatformat(2) }}</td>
                            <td class="num">{{ sm.k_bb_ratio|floatformat(2) }}</td>
                            <td class="num">{{ sm.k_pct|pct_fmt }}</td>
                            <td class="num">{{ sm.bb_pct|pct_fmt }}</td>
                            <td class="num">{{ sm.strike_pct|num_dash }}</td>
                            <td class="num">{{ sm.p_avg|num_dash }}</td>
                            <td class="num">{{ sm.p_obp|num_dash }}</td>
                            <td class="num">{{ sm.p_slg|num_dash }}</td>
                            <td class="num">{{ sm.p_ops|num_dash }}</td>
                            <td class="num">{{ sm.p_babip|floatformat(3) }}</td>
                            <td class="num">{{ sm.p_go_ao|floatformat(2) }}</td>
                            <td class="num">{{ sm.pitches_per_pa|floatformat(2) }}</td>
                        {% else %}
                            <td class="num">{{ sm.k_pct|pct_fmt }}</td>
                            <td class="num">{{ sm.bb_pct|pct_fmt }}</td>
                            <td class="num">{{ sm.iso|floatformat(3) }}</td>
                            <td class="num">{{ sm.babip|floatformat(3) }}</td>
                            <td class="num">{{ sm.xbh|num_dash }}</td>
                            <td class="num">{{ sm.ab_per_hr|floatformat(1) }}</td>
                            <td class="num">{{ sm.go_ao|floatformat(2) }}</td>
                            <td class="num">{{ sm.sb_pct|num_dash }}</td>
                            <td class="num">{{ sm.p_per_pa|floatformat(2) }}</td>
                            <td class="num">{{ sm.ibb|num_dash }}</td>
                            <td class="num">{{ sm.hbp|num_dash }}</td>
                            <td class="num">{{ sm.gdp|num_dash }}</td>
                            <td class="num">{{ sm.gidpo|num_dash }}</td>
                            <td class="num">{{ sm.sac_flies|num_dash }}</td>
                            <td class="num">{{ sm.sac_bunts|num_dash }}</td>
                            <td class="num">{{ sm.lob|num_dash }}</td>
                            <td class="num">{{ sm.roe|num_dash }}</td>
                            <td class="num">{{ sm.wo|num_dash }}</td>
                        {% endif %}
                    </tr>
                    {# ── Per-team detail rows ── #}
                    {% if grp.multi %}
                    {% for stat in grp.rows %}
                    <tr class="year-detail-row" data-tbl="adv" data-grp="{{ yr }}" style="display:none;">
                        <td></td>
                        <td></td>
                        <td>{{ tags.level_tag(stat.sport_level, stat.year) }}</td>
                        <td>{{ stat.team_name }}</td>
                        {% if is_pitcher %}
                            <td class="num">{{ stat.whip|floatformat(2) }}</td>
                            <td class="num">{{ stat.k_per_9|floatformat(1) }}</td>
                            <td class="num">{{ stat.bb_per_9|floatformat(1) }}</td>
                            <td class="num">{{ stat.h_per_9|floatformat(1) }}</td>
                            <td class="num">{{ stat.hr_per_9|floatformat(2) }}</td>
                            <td class="num">{{ stat.k_bb_ratio|floatformat(2) }}</td>
                            <td class="num">{{ stat.k_pct|pct_fmt }}</td>
                            <td class="num">{{ stat.bb_pct|pct_fmt }}</td>
                            <td class="num">{{ stat.strike_pct|num_dash }}</td>
                            <td class="num">{{ stat.p_avg|num_dash }}</td>
                            <td class="num">{{ stat.p_obp|num_dash }}</td>
                            <td class="num">{{ stat.p_slg|num_dash }}</td>
                            <td class="num">{{ stat.p_ops|num_dash }}</td>
                            <td class="num">{{ stat.p_babip|floatformat(3) }}</td>
                            <td class="num">{{ stat.p_go_ao|floatformat(2) }}</td>
                            <td class="num">{{ stat.pitches_per_pa|floatformat(2) }}</td>
                        {% else %}
                            <td class="num">{{ stat.k_pct|pct_fmt }}</td>
                            <td class="num">{{ stat.bb_pct|pct_fmt }}</td>
                            <td class="num">{{ stat.iso|floatformat(3) }}</td>
                            <td class="num">{{ stat.babip|floatformat(3) }}</td>
                            <td class="num">{{ stat.xbh|num_dash }}</td>
                            <td class="num">{{ stat.ab_per_hr|floatformat(1) }}</td>
                            <td class="num">{{ stat.go_ao|floatformat(2) }}</td>
                            <td class="num">{{ stat.sb_pct|num_dash }}</td>
                            <td class="num">{{ stat.p_per_pa|floatformat(2) }}</td>
                            <td class="num">{{ stat.ibb|num_dash }}</td>
                            <td class="num">{{ stat.hbp|num_dash }}</td>
                            <td class="num">{{ stat.gdp|num_dash }}</td>
                            <td class="num">{{ stat.gidpo|num_dash }}</td>
                            <td class="num">{{ stat.sac_flies|num_dash }}</td>
                            <td class="num">{{ stat.sac_bunts|num_dash }}</td>
                            <td class="num">{{ stat.lob|num_dash }}</td>
                            <td class="num">{{ stat.roe|num_dash }}</td>
                            <td class="num">{{ stat.wo|num_dash }}</td>
                        {% endif %}
                    </tr>
                    {% endfor %}
                    {% endif %}
                    {% else %}
                    <tr><td colspan="20" class="td-empty">尚無數據</td></tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>

    {# ── STATCAST OVERVIEW ── #}
    {% if statcast_available %}
    <div class="data-table-section glass-panel">
        <h3>Statcast 概覽</h3>
        <div class="table-scroll">
            <table class="data-table year-group-table" id="stats-table-sc">
                <thead>
                    <tr>
                        <th>年度</th><th>層級</th>
                        {% if is_pitcher %}
                            {{ macros.th('FIP', '守備無關防禦率') }}{{ macros.th('xWPCT', '預期勝率') }}{{ macros.th('wOBA', '被加權上壘率') }}{{ macros.th('xwOBA', '預期被加權上壘率') }}
                            {{ macros.th('Barrel%', '被強勁長打比例') }}{{ macros.th('Hard-Hit%', '被強擊球比例') }}{{ macros.th('Avg EV', '平均被擊球初速') }}
                            {{ macros.th('GB%', '滾地球比例') }}{{ macros.th('HR/FB%', '飛球中被全壘打比例') }}{{ macros.th('Whiff%', '揮空率') }}{{ macros.th('Avg Ext', '平均出手延伸距離') }}
                        {% else %}
                            {{ macros.th('BBE', '進場擊球數') }}{{ macros.th('wOBA', '加權上壘率') }}{{ macros.th('xwOBA', '預期加權上壘率') }}
                            {{ macros.th('wRC+', '得分創造指數，100 為聯盟平均') }}{{ macros.th('WAR', '勝利貢獻值') }}
                            {{ macros.th('Barrel%', '強勁長打比例') }}{{ macros.th('Hard-Hit%', '強擊球比例') }}{{ macros.th('Avg EV', '平均擊球初速') }}
                            {{ macros.th('Max EV', '最高擊球初速') }}{{ macros.th('EV90', '前10%擊球初速平均') }}{{ macros.th('Avg LA', '平均擊球仰角') }}{{ macros.th('SwSp%', '揮空加看球好球比例') }}
                        {% endif %}
                    </tr>
                </thead>
                <tbody>
                    {% for yr in available_statcast_years %}
                    {% set entries = statcast_by_year[yr] %}
                    {% set level_entries = entries if entries|length == 1 else entries[1:] %}
                    {% for entry in level_entries %}
                    {% set sc = entry.sc %}
                    {% set ss_row = entry.stat %}
                    <tr class="{% if yr == selected_year %}highlight-row{% endif %}">
                        <td><strong>{{ yr }}</strong></td>
                        <td>{{ tags.level_tag(entry.sport_level, yr) }}</td>
                        {% if is_pitcher %}
                            <td class="num">{% if ss_row and ss_row.fip %}{{ ss_row.fip|floatformat(2) }}{% else %}—{% endif %}</td>
                            <td class="num">{% if ss_row and ss_row.xwpct %}{{ ss_row.xwpct|floatformat(3) }}{% else %}—{% endif %}</td>
                            <td class="num">{{ sc.woba_against|floatformat(3) }}</td>
                            <td class="num">{% if ss_row and ss_row.expected and ss_row.expected.xwoba %}{{ ss_row.expected.xwoba|floatformat(3) }}{% else %}—{% endif %}</td>
                            <td class="num">{{ sc.barrel_pct|pct_fmt }}</td>
                            <td class="num">{{ sc.hard_hit_pct|pct_fmt }}</td>
                            <td class="num">{{ sc.avg_ev|floatformat(1) }}</td>
                            <td class="num">{{ sc.gb_pct|pct_fmt }}</td>
                            <td class="num">{{ sc.hr_fb_pct|pct_fmt }}</td>
                            <td class="num">{{ sc.whiff_pct|pct_fmt }}</td>
                            <td class="num">{{ sc.avg_extension|floatformat(2) }}</td>
                        {% else %}
                            <td class="num">{{ sc.bbe|num_dash }}</td>
                            <td class="num">{{ sc.woba|floatformat(3) }}</td>
                            <td class="num">{% if ss_row and ss_row.expected and ss_row.expected.xwoba %}{{ ss_row.expected.xwoba|floatformat(3) }}{% else %}—{% endif %}</td>
                            <td class="num">{% if ss_row and ss_row.wrc_plus is not none %}{{ ss_row.wrc_plus }}{% elif ss_row and ss_row.wrc_plus_calc is not none %}{{ ss_row.wrc_plus_calc }}{% else %}—{% endif %}</td>
                            <td class="num">{% if ss_row and ss_row.war %}{{ ss_row.war|floatformat(1) }}{% else %}—{% endif %}</td>
                            <td class="num">{{ sc.barrel_pct|pct_fmt }}</td>
                            <td class="num">{{ sc.hard_hit_pct|pct_fmt }}</td>
                            <td class="num">{{ sc.avg_ev|floatformat(1) }}</td>
                            <td class="num">{{ sc.max_ev|floatformat(1) }}</td>
                            <td class="num">{{ sc.ev90|floatformat(1) }}</td>
                            <td class="num">{{ sc.avg_la|floatformat(1) }}</td>
                            <td class="num">{{ sc.swsp_pct|pct_fmt }}</td>
                        {% endif %}
                    </tr>
                    {% endfor %}
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>

    {# ── PLATE DISCIPLINE ── #}
    <div class="data-table-section glass-panel">
        <h3>Plate Discipline</h3>
        <div class="table-scroll">
            <table class="data-table year-group-table" id="stats-table-pd">
                <thead>
                    <tr>
                        <th>年度</th><th>層級</th>{{ macros.th('Pitches', '總投球數') }}
                        {% if is_pitcher %}
                            {{ macros.th('Zone%', '投進好球帶比例') }}{{ macros.th('Z-Swing%', '好球帶內揮棒率') }}{{ macros.th('O-Swing%', '好球帶外揮棒率') }}
                            {{ macros.th('Z-Contact%', '好球帶內接觸率') }}{{ macros.th('Swing%', '總揮棒率') }}{{ macros.th('Whiff%', '揮空率') }}
                            {{ macros.th('CSW%', '看球好球加揮空比例') }}{{ macros.th('SwStr%', '揮棒落空好球比例') }}
                        {% else %}
                            {{ macros.th('Strike%', '面對投球中的好球比例') }}{{ macros.th('Zone%', '進好球帶比例') }}{{ macros.th('Z-Swing%', '好球帶內揮棒率') }}{{ macros.th('O-Swing%', '好球帶外揮棒率') }}
                            {{ macros.th('Z-Contact%', '好球帶內接觸率') }}{{ macros.th('Swing%', '總揮棒率') }}{{ macros.th('Whiff%', '揮空率') }}
                            {{ macros.th('CSW%', '看球好球加揮空比例') }}{{ macros.th('SwStr%', '揮棒落空好球比例') }}
                        {% endif %}
                    </tr>
                </thead>
                <tbody>
                    {% for yr in available_statcast_years %}
                    {% set entries = statcast_by_year[yr] %}
                    {% set level_entries = entries if entries|length == 1 else entries[1:] %}
                    {% for entry in level_entries %}
                    {% set sc = entry.sc %}
                    <tr class="{% if yr == selected_year %}highlight-row{% endif %}">
                        <td><strong>{{ yr }}</strong></td>
                        <td>{{ tags.level_tag(entry.sport_level, yr) }}</td>
                        <td class="num">{{ sc.total_pitches|num_dash }}</td>
                        {% if is_pitcher %}
                            <td class="num">{{ sc.zone_pct|pct_fmt }}</td>
                            <td class="num">{{ sc.z_swing_pct|pct_fmt }}</td>
                            <td class="num">{{ sc.o_swing_pct|pct_fmt }}</td>
                            <td class="num">{{ sc.z_contact_pct|pct_fmt }}</td>
                            <td class="num">{{ sc.swing_pct|pct_fmt }}</td>
                            <td class="num">{{ sc.whiff_pct|pct_fmt }}</td>
                            <td class="num">{{ sc.csw_pct|pct_fmt }}</td>
                            <td class="num">{{ sc.swstr_pct|pct_fmt }}</td>
                        {% else %}
                            <td class="num">{{ sc.strike_pct|pct_fmt }}</td>
                            <td class="num">{{ sc.zone_pct|pct_fmt }}</td>
                            <td class="num">{{ sc.z_swing_pct|pct_fmt }}</td>
                            <td class="num">{{ sc.o_swing_pct|pct_fmt }}</td>
                            <td class="num">{{ sc.z_contact_pct|pct_fmt }}</td>
                            <td class="num">{{ sc.swing_pct|pct_fmt }}</td>
                            <td class="num">{{ sc.whiff_pct|pct_fmt }}</td>
                            <td class="num">{{ sc.csw_pct|pct_fmt }}</td>
                            <td class="num">{{ sc.swstr_pct|pct_fmt }}</td>
                        {% endif %}
                    </tr>
                    {% endfor %}
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>

    {# ── BATTED BALL PROFILE ── #}
    <div class="data-table-section glass-panel">
        <h3>擊球型態</h3>
        <div class="table-scroll">
            <table class="data-table year-group-table" id="stats-table-bb">
                <thead>
                    <tr>
                        <th>年度</th><th>層級</th>
                        {{ macros.th('BBE', '進場擊球數') }}
                        {{ macros.th('GB%', '滾地球比例') }}{{ macros.th('LD%', '平飛球比例') }}{{ macros.th('FB%', '飛球比例') }}{{ macros.th('PU%', '內野高飛球比例') }}{{ macros.th('Air%', '空中擊球比例（平飛+飛球）') }}
                        {{ macros.th('Pull%', '拉打比例') }}{{ macros.th('Straight%', '中間方向擊球比例') }}{{ macros.th('Oppo%', '反方向擊球比例') }}
                        {% if not is_pitcher %}{{ macros.th('PullAir%', '拉打空中球比例') }}{% endif %}
                    </tr>
                </thead>
                <tbody>
                    {% for yr in available_statcast_years %}
                    {% set entries = statcast_by_year[yr] %}
                    {% set level_entries = entries if entries|length == 1 else entries[1:] %}
                    {% for entry in level_entries %}
                    {% set sc = entry.sc %}
                    {% if sc.bbe is not none %}
                    <tr class="{% if yr == selected_year %}highlight-row{% endif %}">
                        <td><strong>{{ yr }}</strong></td>
                        <td>{{ tags.level_tag(entry.sport_level, yr) }}</td>
                        <td class="num">{{ sc.bbe|num_dash }}</td>
                        <td class="num">{{ sc.gb_pct|pct_fmt }}</td>
                        <td class="num">{{ sc.ld_pct|pct_fmt }}</td>
                        <td class="num">{{ sc.fb_pct|pct_fmt }}</td>
                        <td class="num">{{ sc.pu_pct|pct_fmt }}</td>
                        <td class="num">{{ sc.air_pct|pct_fmt }}</td>
                        <td class="num">{{ sc.pull_pct|pct_fmt }}</td>
                        <td class="num">{{ sc.straight_pct|pct_fmt }}</td>
                        <td class="num">{{ sc.oppo_pct|pct_fmt }}</td>
                        {% if not is_pitcher %}<td class="num">{{ sc.pull_air_pct|pct_fmt }}</td>{% endif %}
                    </tr>
                    {% endif %}
                    {% endfor %}
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>

    {# Pitch Arsenal / VS PITCH TYPE ── #}
    <div class="data-table-section glass-panel">
        <h3>{% if is_pitcher %}投球球種分析{% else %}對戰球種分析{% endif %}</h3>

        {# Year + Level filter for arsenal/vs tables #}
        <div class="log-filter-bar" style="margin-bottom:0.75rem;">
            <label class="filter-label" for="arsenal-year-select">年度</label>
            <select id="arsenal-year-select" class="filter-select">
                {% for yr in available_statcast_years %}
                <option value="{{ yr }}"{% if loop.first %} selected{% endif %}>{{ yr }}</option>
                {% endfor %}
            </select>
            <label class="filter-label" for="arsenal-level-select">層級</label>
            <select id="arsenal-level-select" class="filter-select"></select>
            {% if is_pitcher %}
            <label class="filter-label" for="arsenal-bat-side-select">對戰打者</label>
            <select id="arsenal-bat-side-select" class="filter-select">
                <option value="all" selected>全部</option>
                <option value="L">左打</option>
                <option value="R">右打</option>
            </select>
            {% endif %}
        </div>

        {% for yr in available_statcast_years %}
        {% set _entries = statcast_by_year[yr] %}
        {# _entries has a _combined prepended when >1 real level exists #}
        {% set _has_multiple = _entries|length > 1 %}
        <div class="arsenal-table-container" id="arsenal-{{ yr }}" {% if not loop.first %}style="display: none;"{% endif %}>

            {% for _e in _entries %}
            {% set sc = _e.sc %}
            {% set _level = _e.sport_level %}
            <div class="arsenal-level-container" id="arsenal-{{ yr }}-{{ _level }}"
                 data-level="{{ _level | level_display(yr) }}"
                 data-level-label="{% if _level == '_combined' %}All Levels{% else %}{{ _level | level_display(yr) }}{% endif %}"
                 {% if not loop.first %}style="display: none;"{% endif %}>
                {% if is_pitcher %}
                {% set splits = sc.pitcher_bat_side_splits if sc.pitcher_bat_side_splits else {} %}
                {% for _side in ["all", "L", "R"] %}
                {% set split = splits.get(_side) if splits else none %}
                {% if not split and _side == "all" %}
                    {% set arsenal = sc.pitch_arsenal if sc.pitch_arsenal else [] %}
                    {% set outcomes = sc.pitch_outcomes if sc.pitch_outcomes else [] %}
                    {% set usage = sc.pitch_usage_by_count if sc.pitch_usage_by_count else {} %}
                {% else %}
                    {% set arsenal = split.pitch_arsenal if split and split.pitch_arsenal else [] %}
                    {% set outcomes = split.pitch_outcomes if split and split.pitch_outcomes else [] %}
                    {% set usage = split.pitch_usage_by_count if split and split.pitch_usage_by_count else {} %}
                {% endif %}
                {% set usage_types = usage.pitch_types if usage and usage.pitch_types else [] %}
                {% set usage_rows = usage.rows if usage and usage.rows else [] %}
                <div class="arsenal-split-container" data-bat-side="{{ _side }}" {% if not loop.first %}style="display: none;"{% endif %}>
                    {% if arsenal or outcomes or usage_types %}
                    <div class="arsenal-table-stack">
                        <section class="arsenal-subsection">
                            <h4 class="arsenal-subtitle">球種數據</h4>
                            <div class="table-scroll">
                                <table class="data-table">
                                    <thead>
                                        <tr>
                                            {{ macros.th('球種', '投手球種') }}{{ macros.th('Pitch%', '該球種使用比例') }}{{ macros.th('Velo', '平均球速') }}{{ macros.th('iVB', '誘導垂直位移') }}{{ macros.th('HB', '水平位移') }}
                                            {{ macros.th('Spin', '平均轉速') }}{{ macros.th('Ext.', '出手延伸距離') }}{{ macros.th('vRel', '垂直出手點') }}{{ macros.th('hRel', '水平出手點') }}
                                            {{ macros.th('Zone%', '進好球帶比例') }}{{ macros.th('Chase%', '誘使追打比例') }}{{ macros.th('Whiff%', '揮空率') }}
                                        </tr>
                                    </thead>
                                    <tbody>
                                        {% for pt in arsenal %}
                                        <tr>
                                            <td>{{ tags.pitch_tag(pt.type, pt.name) }}</td>
                                            <td class="num">{{ pt.pct|pct_fmt }}</td>
                                            <td class="num">{{ pt.velo|floatformat(1) }}</td>
                                            <td class="num">{{ pt.ivb|floatformat(1) }}</td>
                                            <td class="num">{{ pt.hb|floatformat(1) }}</td>
                                            <td class="num">{{ pt.spin|num_dash }}</td>
                                            <td class="num">{{ pt.extension|floatformat(2) }}</td>
                                            <td class="num">{{ pt.v_rel|floatformat(2) }}</td>
                                            <td class="num">{{ pt.h_rel|floatformat(2) }}</td>
                                            <td class="num">{{ pt.zone_pct|pct_fmt }}</td>
                                            <td class="num">{{ pt.chase_pct|pct_fmt }}</td>
                                            <td class="num">{{ pt.whiff_pct|pct_fmt }}</td>
                                        </tr>
                                        {% else %}
                                        <tr><td colspan="12" class="td-empty">無球種資料</td></tr>
                                        {% endfor %}
                                    </tbody>
                                </table>
                            </div>
                        </section>

                        <section class="arsenal-subsection">
                            <h4 class="arsenal-subtitle">對戰結果</h4>
                            <div class="table-scroll">
                                <table class="data-table">
                                    <thead>
                                        <tr>
                                            {{ macros.th('球種', '投手球種') }}{{ macros.th('Pitches', '該球種投球數') }}{{ macros.th('Pitch%', '該球種使用比例') }}{{ macros.th('Strike%', '好球比例') }}
                                            {{ macros.th('Z-Whiff%', '好球帶內揮空率') }}{{ macros.th('O-Swing%', '好球帶外揮棒率') }}{{ macros.th('SwStr%', '揮棒落空好球比例') }}{{ macros.th('CSW%', '看球好球加揮空比例') }}
                                            {{ macros.th('PutAway%', '兩好球後解決打者比例') }}{{ macros.th('AVG', '被打擊率') }}{{ macros.th('wOBA', '被加權上壘率') }}{{ macros.th('Barrel%', '被強勁長打比例') }}{{ macros.th('HardHit%', '被強擊球比例') }}
                                        </tr>
                                    </thead>
                                    <tbody>
                                        {% for pt in outcomes %}
                                        <tr>
                                            <td>{{ tags.pitch_tag(pt.type, pt.name) }}</td>
                                            <td class="num">{{ pt.count|num_dash }}</td>
                                            <td class="num">{{ pt.pct|pct_fmt }}</td>
                                            <td class="num">{{ pt.strike_pct|pct_fmt }}</td>
                                            <td class="num">{{ pt.z_whiff_pct|pct_fmt }}</td>
                                            <td class="num">{{ pt.o_swing_pct|pct_fmt }}</td>
                                            <td class="num">{{ pt.swstr_pct|pct_fmt }}</td>
                                            <td class="num">{{ pt.csw_pct|pct_fmt }}</td>
                                            <td class="num">{{ pt.put_away_pct|pct_fmt }}</td>
                                            <td class="num">{{ pt.avg|floatformat(3) }}</td>
                                            <td class="num">{{ pt.woba|floatformat(3) }}</td>
                                            <td class="num">{{ pt.barrel_pct|pct_fmt }}</td>
                                            <td class="num">{{ pt.hard_hit_pct|pct_fmt }}</td>
                                        </tr>
                                        {% else %}
                                        <tr><td colspan="13" class="td-empty">無球種資料</td></tr>
                                        {% endfor %}
                                    </tbody>
                                </table>
                            </div>
                        </section>

                        <section class="arsenal-subsection">
                            <h4 class="arsenal-subtitle">各球數配球比例</h4>
                            {% if usage_types and usage_rows %}
                            <div class="table-scroll">
                                <table class="data-table pitch-usage-table">
                                    <thead>
                                        <tr>
                                            {{ macros.th('球種', '投手球種') }}
                                            {% for row in usage_rows %}
                                            {% if row.key != 'all' %}
                                            {% call macros.th_html(tooltip="該球數下此球種的使用比例") %}{{ row.label }}<br><span class="pitch-usage-subhead">{{ row.counts_label }}</span>{% endcall %}
                                            {% endif %}
                                            {% endfor %}
                                        </tr>
                                    </thead>
                                    <tbody>
                                        {% for pitch in usage_types %}
                                        <tr>
                                            <td>{{ tags.pitch_tag(pitch.type, pitch.name) }}</td>
                                            {% for row in usage_rows %}
                                            {% if row.key != 'all' %}
                                            {% set pitch_cell = namespace(pct=none) %}
                                            {% for pt in row.pitch_types %}
                                            {% if pt.type == pitch.type %}
                                            {% set pitch_cell.pct = pt.pct %}
                                            {% endif %}
                                            {% endfor %}
                                            <td class="num">{{ pitch_cell.pct|pct_fmt }}</td>
                                            {% endif %}
                                            {% endfor %}
                                        </tr>
                                        {% endfor %}
                                    </tbody>
                                </table>
                            </div>
                            {% else %}
                            <div class="pitch-analysis-empty">無球種資料</div>
                            {% endif %}
                        </section>
                    </div>
                    {% else %}
                    <div class="pitch-analysis-empty">無球種資料</div>
                    {% endif %}
                </div>
                {% endfor %}
                {% else %}
                <div class="table-scroll">
                {% set vs = sc.vs_pitch_types if sc.vs_pitch_types else [] %}
                <table class="data-table">
                    <thead>
                        <tr>
                            {{ macros.th('球種', '面對球種') }}{{ macros.th('Pitches', '面對該球種投球數') }}{{ macros.th('Strike%', '好球比例') }}{{ macros.th('Zone%', '進好球帶比例') }}
                            {{ macros.th('Z-Swing%', '好球帶內揮棒率') }}{{ macros.th('O-Swing%', '好球帶外揮棒率') }}{{ macros.th('Whiff%', '揮空率') }}{{ macros.th('SwStr%', '揮棒落空好球比例') }}
                            {{ macros.th('CSW%', '看球好球加揮空比例') }}{{ macros.th('Put Away%', '兩好球後被解決比例') }}{{ macros.th('AVG', '對該球種打擊率') }}{{ macros.th('wOBA', '對該球種加權上壘率') }}
                            {{ macros.th('Barrel%', '對該球種強勁長打比例') }}{{ macros.th('Hard-Hit%', '對該球種強擊球比例') }}
                        </tr>
                    </thead>
                    <tbody>
                        {% for pt in vs %}
                        <tr>
                            <td>{{ tags.pitch_tag(pt.type, pt.name) }}</td>
                            <td class="num">{{ pt.count|num_dash }}</td>
                            <td class="num">{{ pt.strike_pct|pct_fmt }}</td>
                            <td class="num">{{ pt.zone_pct|pct_fmt }}</td>
                            <td class="num">{{ pt.z_swing_pct|pct_fmt }}</td>
                            <td class="num">{{ pt.o_swing_pct|pct_fmt }}</td>
                            <td class="num">{{ pt.whiff_pct|pct_fmt }}</td>
                            <td class="num">{{ pt.swstr_pct|pct_fmt }}</td>
                            <td class="num">{{ pt.csw_pct|pct_fmt }}</td>
                            <td class="num">{{ pt.put_away_pct|pct_fmt }}</td>
                            <td class="num">{{ pt.avg|floatformat(3) }}</td>
                            <td class="num">{{ pt.woba|floatformat(3) }}</td>
                            <td class="num">{{ pt.barrel_pct|pct_fmt }}</td>
                            <td class="num">{{ pt.hard_hit_pct|pct_fmt }}</td>
                        </tr>
                        {% else %}
                        <tr><td colspan="14" class="td-empty">尚無數據</td></tr>
                        {% endfor %}
                    </tbody>
                </table>
                </div>
                {% endif %}
            </div>
            {% endfor %}

        </div>
        {% endfor %}
    </div>
    {% else %}
    <div class="glass-panel empty-season-msg">
        尚無 Statcast 數據
    </div>
    {% endif %}

</div>
